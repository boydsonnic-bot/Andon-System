@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Production KPI Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Nunito',system-ui,sans-serif;font-size:12px;background:#f1f5f9;color:#0f172a;height:100vh;overflow:hidden}
:root{
  --bg1:#fff;--bg2:#f8fafc;--bg3:#e2e8f0;
  --t1:#0f172a;--t2:#475569;--t3:#94a3b8;
  --bdr:#e2e8f0;--rl:12px;--rm:8px;
  --g:#10b981;--y:#f59e0b;--r:#ef4444;--b:#3b82f6;--p:#8b5cf6;--o:#f97316;
}
#app{max-width:1600px;margin:0 auto;padding:8px 12px;height:100%;display:flex;flex-direction:column;gap:8px}

/* HEADER */
.hdr{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;background:var(--bg1);padding:8px 16px;border-radius:var(--rl);border:1px solid var(--bdr)}
.ht{font-size:15px;font-weight:900;display:flex;align-items:center;gap:8px}
.hd{width:8px;height:8px;border-radius:50%;background:var(--g);animation:pu 2s infinite}
@@keyframes pu{0%,100%{opacity:1}50%{opacity:.3}}

/* KPI ROW */
.krow{flex-shrink:0;display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:8px}
.kc{background:var(--bg1);border-radius:var(--rl);padding:8px 12px;border:1px solid var(--bdr);border-left:4px solid}
.kl{font-size:9px;font-weight:800;color:var(--t2);text-transform:uppercase;margin-bottom:2px;letter-spacing:.3px}
.kv{font-size:19px;font-weight:900;line-height:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ks{font-size:9px;color:var(--t3);margin-top:2px;font-weight:700}

/* CONTROLS */
.ctrl{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:8px}
.cg{display:flex;align-items:center;gap:5px;background:var(--bg1);padding:3px 8px;border-radius:9999px;border:1px solid var(--bdr)}
.si{border:none;outline:none;font-size:12px;padding:2px 5px;width:140px;background:transparent;font-family:'Nunito',inherit;font-weight:700}
.di{border:none;outline:none;font-size:11px;padding:2px;background:transparent;color:var(--t1);font-family:inherit;font-weight:700}
.bf{background:var(--b);color:#fff;border:none;border-radius:9999px;padding:3px 11px;font-size:11px;font-weight:800;cursor:pointer;font-family:inherit}
.pb{padding:4px 12px;border-radius:9999px;cursor:pointer;font-size:12px;font-weight:800;border:1px solid var(--bdr);background:#fff;color:var(--t2);font-family:inherit;transition:.1s}
.pb.on{background:var(--b);color:#fff;border-color:var(--b)}
.ss{padding:4px 10px;border-radius:9999px;font-size:12px;font-weight:800;border:1px solid var(--bdr);background:#fff;outline:none;font-family:inherit;color:var(--t1)}

/* MIDDLE CHARTS */
.mrow{flex-shrink:0;display:flex;gap:8px;height:150px}
.pb2{background:var(--bg1);border:1px solid var(--bdr);border-radius:var(--rl);padding:8px 12px;display:flex;flex-direction:column;min-height:0}
.pt{font-size:11px;font-weight:800;color:var(--t1);text-transform:uppercase;margin-bottom:5px;flex-shrink:0}
.cw{flex:1;position:relative;min-height:0;width:100%;height:100%}

/* BOTTOM SPLIT */
.bs{flex:1;min-height:0;display:flex;gap:8px}

/* LEFT LIST */
.ll{flex:0 0 22%;overflow-y:auto;display:flex;flex-direction:column;gap:7px;padding-right:3px}
.ll::-webkit-scrollbar{width:4px}
.ll::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:3px}

.lc{flex-shrink:0;background:var(--bg1);border:1px solid var(--bdr);border-radius:var(--rm);padding:9px 10px;cursor:pointer;transition:.15s}
.lc.active{border-color:var(--b);box-shadow:0 0 0 1.5px var(--b);background:#f0f7ff}
.lc:hover:not(.active){border-color:#93c5fd}
.ln{font-size:13px;font-weight:900;margin-bottom:4px;display:flex;align-items:center;justify-content:space-between}
.lbadge{font-size:9px;padding:1px 6px;border-radius:9999px;font-weight:800;border:1px solid}
.lbr{margin-bottom:3px}
.lbl2{display:flex;justify-content:space-between;font-size:9px;font-weight:800;color:var(--t2);margin-bottom:2px}
.lbt{height:4px;background:var(--bg3);border-radius:2px;overflow:hidden}
.lbf{height:100%;border-radius:2px;transition:width .5s ease}
.lmc{font-size:9px;color:var(--t3);font-weight:700;margin-top:4px}

/* RIGHT DETAIL */
.rd{flex:1;background:var(--bg1);border:1px solid var(--bdr);border-radius:var(--rl);padding:10px 14px;display:flex;flex-direction:column;min-height:0;overflow:hidden}
.dh{flex-shrink:0;display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;border-bottom:1px solid #f1f5f9;padding-bottom:6px}
.dht{font-size:16px;font-weight:900;color:var(--t1)}

/* Stats donuts */
.dstats{flex-shrink:0;display:grid;grid-template-columns:repeat(6,1fr);gap:5px;margin-bottom:7px;background:var(--bg2);padding:7px;border-radius:var(--rm);border:1px solid #f1f5f9}
.dsi{display:flex;flex-direction:column;align-items:center}
.dsv{font-size:17px;font-weight:900;line-height:1.2}
.dsl{font-size:8px;font-weight:800;color:var(--t2);text-transform:uppercase;margin-bottom:3px;text-align:center}
.ddo{border-radius:50%;display:flex;align-items:center;justify-content:center;margin-bottom:2px}
.ddi{background:var(--bg2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:900}

/* Model strip */
.mstrip{flex-shrink:0;margin-bottom:6px}
.mstrip-lbl{font-size:9px;font-weight:800;color:var(--t2);text-transform:uppercase;margin-bottom:4px;letter-spacing:.3px}
.mstrip-row{display:flex;gap:5px;overflow-x:auto;padding-bottom:3px}
.mstrip-row::-webkit-scrollbar{height:3px}
.mstrip-row::-webkit-scrollbar-thumb{background:#cbd5e1;border-radius:2px}
.mc{flex-shrink:0;display:flex;flex-direction:column;background:var(--bg2);border:1.5px solid var(--bdr);border-radius:var(--rm);padding:6px 8px;cursor:pointer;min-width:108px;transition:.15s}
.mc.sel{border-color:var(--b);background:#eff6ff}
.mc:hover:not(.sel){border-color:#93c5fd}
.mc-nm{font-size:10px;font-weight:900;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:3px}
.mc-pct{font-size:14px;font-weight:900;line-height:1}
.mc-sub{font-size:9px;color:var(--t2);font-weight:700}
.mc-bar{height:3px;background:var(--bg3);border-radius:2px;overflow:hidden;margin-top:4px}
.mc-barf{height:100%;border-radius:2px;transition:width .4s ease}

/* Tabs */
.tabs{flex-shrink:0;display:flex;border-bottom:1px solid var(--bdr);margin-bottom:6px}
.tab{padding:3px 14px;cursor:pointer;font-size:11px;font-weight:800;border-bottom:2px solid transparent;color:var(--t2)}
.tab.on{border-bottom-color:var(--b);color:var(--b)}

/* Charts */
.ca{flex:1;display:flex;flex-direction:column;gap:6px;min-height:0}
.cr{display:flex;gap:6px;flex:1;min-height:0}
.cb{flex:1;border:1px solid var(--bdr);border-radius:var(--rm);padding:7px 10px;display:flex;flex-direction:column;min-height:0}
.ct{font-size:9px;font-weight:800;color:var(--t2);text-transform:uppercase;margin-bottom:5px;flex-shrink:0}

.bz{background:var(--bg2);border:1px solid var(--bdr);color:var(--t1);cursor:pointer;padding:4px 10px;border-radius:6px;font-size:11px;font-weight:900;font-family:inherit;transition:.15s}
.bz:hover{background:var(--b);color:#fff;border-color:var(--b)}

/* ZOOM MODAL */
#zmod{display:none;opacity:0;position:fixed;inset:0;background:rgba(15,23,42,.85);z-index:9999;align-items:center;justify-content:center;padding:16px;transition:opacity .2s}
.zmb{background:#fff;border-radius:16px;width:95vw;height:90vh;display:flex;flex-direction:column;padding:18px;position:relative;box-shadow:0 25px 50px -12px rgba(0,0,0,.5);overflow:hidden}
.zmc{position:absolute;top:14px;right:14px;width:32px;height:32px;border:none;border-radius:8px;background:#f1f5f9;cursor:pointer;font-size:16px;font-weight:900;color:#64748b;font-family:inherit}
</style>
</head>
<body>
<div id="app">

  <div class="hdr">
    <div class="ht"><span class="hd"></span> PRODUCTION KPI DASHBOARD</div>
    <div style="display:flex;align-items:center;gap:10px">
      <span id="last-upd" style="font-size:10px;color:#94a3b8;font-weight:700"></span>
      <span id="file-status" style="font-size:11px;padding:3px 8px;border-radius:6px;font-weight:800;background:var(--bg3)">Loading...</span>
      <span style="font-size:13px;color:var(--t2);font-weight:800" id="clk"></span>
      <a href="/Home" style="text-decoration:none;background:var(--r);color:#fff;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:800">🚨 Andon</a>
      <a href="/Spc"  style="text-decoration:none;background:var(--p);color:#fff;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:800">📈 SPC</a>
      <button onclick="toggleFS()" style="background:var(--bg2);border:1px solid var(--bdr);color:var(--t1);cursor:pointer;padding:5px 12px;border-radius:6px;font-size:12px;font-weight:800;font-family:inherit">⛶ Fullscreen</button>
    </div>
  </div>

  <div class="krow" id="krow"></div>

  <div class="ctrl">
    <div style="display:flex;align-items:center;gap:8px">
      <div class="cg"><span style="font-size:12px">🔍</span><input class="si" id="sb" placeholder="Search Model / Line..." onkeyup="filt()"></div>
      <div class="cg">
        <span style="font-size:9px;color:var(--t2);font-weight:800;margin-left:3px">FROM</span>
        <input type="date" class="di" id="df">
        <span style="font-size:9px;color:var(--t2);font-weight:800">TO</span>
        <input type="date" class="di" id="dt">
        <button class="bf" onclick="applyDate()">Filter</button>
      </div>
    </div>
    <div style="display:flex;align-items:center;gap:6px">
      <select class="ss" id="so" onchange="filt()">
        <option value="line_asc">▼ Model (A-Z)</option>
        <option value="line_desc">▲ Model (Z-A)</option>
        <option value="kpi_desc">▼ Performance High→Low</option>
        <option value="kpi_asc">▲ Performance Low→High</option>
      </select>
      <div style="display:flex;gap:4px">
        <button class="pb on" id="period-day"   onclick="sp('day')">Today</button>
        <button class="pb"    id="period-week"  onclick="sp('week')">This Week</button>
        <button class="pb"    id="period-month" onclick="sp('month')">This Month</button>
        <button class="pb"    id="period-ytd"   onclick="sp('ytd')">YTD</button>
      </div>
    </div>
  </div>

  <div class="mrow">
    <div class="pb2" style="flex:2.2"><div class="pt">📊 Yearly Production Output (YTD)</div><div class="cw"><canvas id="ytdC"></canvas></div></div>
    <div class="pb2" style="flex:1"><div class="pt">📉 Top Quality Issues (Pareto)</div><div class="cw"><canvas id="parC"></canvas></div></div>
  </div>

  <div class="bs">
    <div class="ll" id="ll"></div>
    <div class="rd" id="rd">
      <div style="height:100%;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:15px;font-weight:800">Select a Model from the left →</div>
    </div>
  </div>

</div>

<div id="zmod" onclick="if(event.target===this)closeZ()">
  <div class="zmb">
    <button class="zmc" onclick="closeZ()">✕</button>
    <div id="zh" style="display:flex;flex-direction:column;height:100%;overflow:hidden"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
Chart.defaults.font.family="'Nunito',system-ui,sans-serif";

// ────────────────────────────────────────────────────────────────
// 1. DATA & BASE STRUCTURE (Lật ngược: Model -> Chuyền)
// ────────────────────────────────────────────────────────────────
let rawPD = [];
const SC = {green:'#10b981',yellow:'#f59e0b',red:'#ef4444',orange:'#f97316',blue:'#3b82f6'};
const SL = {green:'Running',yellow:'Waiting KTV',red:'Stopped',orange:'Repairing',blue:'Confirm'};

function buildBaseLines(src) {
    if (!src || src.length === 0) return [];

    // Tự động tìm ngày mới nhất trong dữ liệu để hiển thị làm "Today"
    const maxDate = src.reduce((max, p) => p.date > max ? p.date : max, src[0].date);
    const todayData = src.filter(x => x.date === maxDate);

    const grouped = {};
    todayData.forEach(row => {
        const key = row.model || 'Unknown Model';
        if (!grouped[key]) {
            grouped[key] = { nm: key, factory: row.factory || 'Factory', status: 'green', lines: [] };
        }
        grouped[key].lines.push({
            id: row.line + "_" + (row.workOrder || 'WO'),
            line: row.line || 'Unknown Line',
            workOrder: row.workOrder || 'WO-NONE',
            target: Number(row.target || 0),
            actual: Number(row.actual || 0),
            mrb: Number(row.mrb || 0),
            status: 'green' // Mặc định xanh, nối Andon DB sẽ set đỏ
        });
    });

    let i = 0;
    return Object.values(grouped).map(g => {
        g._uid = 'M' + (i++);
        // Fake lại tên mảng thành `models` để UI cũ chạy mượt mà không crash
        g.models = g.lines.map((l, j) => ({
            id: g._uid + '_L' + j,
            model: l.line, // UI cũ hiển thị model, ta tráo bằng Line
            workOrder: l.workOrder,
            target: l.target,
            actual: l.actual,
            mrb: l.mrb,
            stopMin: 0,
            status: l.status,
            ewma: Math.floor(Math.random() * 20 + 10),
            zscore: +(Math.random() * 2.8).toFixed(1),
            pattern: 'low'
        }));
        delete g.lines;
        return g;
    });
}

function enrichLine(l){
    const t = l.models.reduce((a,m)=>a+m.target,0);
    const a = l.models.reduce((a,m)=>a+m.actual,0); 
    const s = l.models.reduce((a,m)=>a+m.stopMin,0);
    
    const isRed = l.models.some(x => x.status === 'red');
    l.status = isRed ? 'red' : 'green';

    return{...l, tot_t:t, tot_a:a, tot_s:s,
           statusCol: SC[l.status] || SC.green, 
           statusTxt: SL[l.status] || 'Running',
           reason: ''};
}

function mkPeriod(lines,mt,ma,ms){
    return lines.map(l=>({...l,
        tot_t:l.tot_t*mt, tot_a:l.tot_a*ma, tot_s:l.tot_s*ms,
        models:l.models.map(m=>({...m, target:m.target*mt, actual:m.actual*ma, stopMin:m.stopMin*ms}))
    }));
}

let BASE = [];
let PER = { day: [], week: [], month: [], ytd: [] };
const PL = {day:'Today',week:'This Week',month:'This Month',ytd:'Year to Date'};
let curP='day', curLines=[], dispLines=[];
let selLine=null, selModel=null, curTab='today', isZoom=false;

// ────────────────────────────────────────────────────────────────
// 2. UTILITIES
// ────────────────────────────────────────────────────────────────
function clock(){ document.getElementById('clk').textContent = new Date().toLocaleString('en-US',{weekday:'short',day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}); }

function fmtT(m){
    if(!m||m<=0) return '0m';
    const mo=Math.floor(m/43200),d=Math.floor((m%43200)/1440),h=Math.floor((m%1440)/60),mn=Math.floor(m%60);
    const r=[];if(mo>0)r.push(mo+'mo');if(d>0)r.push(d+'d');if(h>0)r.push(h+'h');if(mn>0||!r.length)r.push(mn+'m');
    return r.join(' ');
}

function toggleFS(){ if(!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{}); else document.exitFullscreen(); }

// ────────────────────────────────────────────────────────────────
// 3. PERIOD & FILTER
// ────────────────────────────────────────────────────────────────
function sp(p){
    curP=p; curLines=[...PER[p]];
    document.querySelectorAll('.pb').forEach(b=>b.classList.remove('on'));
    document.getElementById('period-'+p).classList.add('on');
    document.getElementById('df').value=''; document.getElementById('dt').value='';
    filt();
}

function applyDate(){
    const f=document.getElementById('df').value, t=document.getElementById('dt').value;
    if(!f||!t) return alert("Please select both dates.");
    if(new Date(f)>new Date(t)) return alert("Start date cannot be after end date.");
    const days=Math.max(1,Math.floor((new Date(t)-new Date(f))/86400000)+1);
    document.querySelectorAll('.pb').forEach(b=>b.classList.remove('on'));
    curP='custom';
    curLines=mkPeriod(BASE,days,Math.round(days*0.95),days);
    filt();
}

function filt(){
    const txt=document.getElementById('sb').value.toLowerCase();
    const so=document.getElementById('so').value;
    dispLines=curLines.filter(l=>l.nm.toLowerCase().includes(txt)||l.models.some(m=>m.model.toLowerCase().includes(txt)));
    dispLines.sort((a,b)=>{
        const pa=a.tot_t>0?a.tot_a/a.tot_t:0, pb=b.tot_t>0?b.tot_a/b.tot_t:0;
        if(so==='line_asc') return a.nm.localeCompare(b.nm);
        if(so==='line_desc') return b.nm.localeCompare(a.nm);
        if(so==='kpi_desc') return pb-pa;
        if(so==='kpi_asc') return pa-pb;
        return 0;
    });
    renderKPI(); renderLeft();
    if(dispLines.length>0){
        if(!dispLines.find(l=>l._uid===selLine?._uid)) selLine=dispLines[0];
        showDetail(selLine._uid);
    } else {
        document.getElementById('rd').innerHTML=`<div style="height:100%;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:14px;font-weight:800">No Data Found</div>`;
    }
}

// ────────────────────────────────────────────────────────────────
// 4. KPI STRIP
// ────────────────────────────────────────────────────────────────
function renderKPI(){
    const tot=dispLines.reduce((a,l)=>a+l.tot_t,0);
    const act=dispLines.reduce((a,l)=>a+l.tot_a,0);
    const perf=tot>0?Math.round(act/tot*100):0;
    const totStop=dispLines.reduce((a,l)=>a+l.tot_s,0);
    let sumOEE=0, sumFPY=0;
    const shm=480*(curP==='week'?5:curP==='month'?21:curP==='ytd'?78:curP==='custom'?7:1);
    dispLines.forEach(l=>{
        const pw=Math.min(l.tot_t>0?Math.round(l.tot_a/l.tot_t*100):0,100);
        const avgMrb=l.models.reduce((a,m)=>a+(m.mrb||0),0)/Math.max(1,l.models.length);
        const fpy=Math.max(0,100-avgMrb);
        const avail=Math.max(0,100-Math.min(100,Math.round((l.tot_s/shm)*100)));
        sumOEE+=Math.round(avail/100*pw/100*fpy/100*100); sumFPY+=fpy;
    });
    const n=dispLines.length||1;
    const avgOEE=Math.round(sumOEE/n), avgFPY=(sumFPY/n).toFixed(1);
    const pc=perf>=90?'var(--g)':perf>=75?'var(--y)':'var(--r)';
    const oc=avgOEE>=85?'var(--b)':avgOEE>=70?'var(--y)':'var(--r)';
    const fc=avgFPY>=95?'var(--g)':avgFPY>=90?'var(--y)':'var(--r)';
    const pl=PL[curP]||'Custom Range';
    
    document.getElementById('krow').innerHTML=[
        {l:'Total Target',    v:tot.toLocaleString('en-US'), s:pl,                  c:'var(--b)', vc:'var(--t1)'},
        {l:'Total Actual',    v:act.toLocaleString('en-US'), s:perf+'% of target',  c:'var(--g)', vc:'var(--g)'},
        {l:'Overall Perf.',   v:perf+'%',                    s:perf>=90?'On track':'Below target', c:pc,vc:pc},
        {l:'Average FPY',     v:avgFPY+'%',                  s:'First Pass Yield',  c:fc,vc:fc},
        {l:'Average OEE',     v:avgOEE+'%',                  s:'Overall Equip. Eff.', c:oc,vc:oc},
        {l:'Total Downtime',  v:fmtT(totStop),               s:'All lines',         c:'var(--r)', vc:'var(--r)'},
    ].map(k=>`<div class="kc" style="border-left-color:${k.c}"><div class="kl">${k.l}</div><div class="kv" style="color:${k.vc}">${k.v}</div><div class="ks">${k.s}</div></div>`).join('');
}

// ────────────────────────────────────────────────────────────────
// 5. LEFT LIST (Model)
// ────────────────────────────────────────────────────────────────
function renderLeft(){
    document.getElementById('ll').innerHTML = dispLines.map(l=>{
        const pct=l.tot_t>0?Math.round(l.tot_a/l.tot_t*100):0;
        const pw=Math.min(pct,100);
        const bc=pct>=90?'var(--g)':pct>=75?'var(--y)':'var(--r)';
        const act=l._uid===selLine?._uid?'active':'';
        return`<div class="lc ${act}" onclick="showDetail('${l._uid}')">
          <div class="ln">
            <span style="font-size:15px; color:var(--b)">${l.nm}</span>
            <span class="lbadge" style="border-color:${l.statusCol}33;color:${l.statusCol};background:${l.statusCol}11">${l.statusTxt}</span>
          </div>
          <div class="lbr"><div class="lbl2"><span>Target</span><span>${l.tot_t.toLocaleString()}</span></div><div class="lbt"><div class="lbf" style="width:100%;background:var(--b)"></div></div></div>
          <div class="lbr"><div class="lbl2"><span>Actual</span><span style="color:${bc}">${l.tot_a.toLocaleString()}</span></div><div class="lbt"><div class="lbf" style="width:${pw}%;background:${bc}"></div></div></div>
          <div class="lmc">Chạy trên ${l.models.length} chuyền &nbsp;·&nbsp; ${pct}% performance</div>
        </div>`;
    }).join('');
}

// ────────────────────────────────────────────────────────────────
// 6. RIGHT DETAIL
// ────────────────────────────────────────────────────────────────
function showDetail(uid){
    const l=dispLines.find(x=>x._uid===uid);
    if(!l) return;
    selLine=l;
    if(!selModel||!l.models.find(m=>m.id===selModel?.id)) selModel=l.models[0];
    renderLeft();
    renderDetail(false);
}

function calcLineStats(l){
    const pct=l.tot_t>0?Math.round(l.tot_a/l.tot_t*100):0;
    const pctW=Math.min(pct,100);
    const bc=pct>=90?'var(--g)':pct>=75?'var(--y)':'var(--r)';
    const shm=480*(curP==='week'?5:curP==='month'?21:curP==='ytd'?78:curP==='custom'?7:1);
    const avgMrb=l.models.reduce((a,m)=>a+(m.mrb||0),0)/Math.max(1,l.models.length);
    const fpy=Math.max(0,100-avgMrb);
    const dp=Math.min(100,Math.round((l.tot_s/shm)*100));
    const avail=Math.max(0,100-dp);
    const oee=Math.round(avail/100*pctW/100*fpy/100*100);
    return{pct,pctW,bc,fpy,dp,avail,oee};
}

function donut(pct,col,sz,isz){
    return`<div class="ddo" style="width:${sz}px;height:${sz}px;background:conic-gradient(${col} ${Math.round(pct)}%,#f1f5f9 0)">
              <div class="ddi" style="width:${isz}px;height:${isz}px;color:${col};font-size:${isz>38?11:10}px">${Math.round(pct)}%</div>
           </div>`;
}

function renderDetail(zoom){
    const l=selLine; if(!l) return;
    const{pct,pctW,bc,fpy,dp,avail,oee}=calcLineStats(l);
    const pfx=zoom?'z':'';
    const pl=PL[curP]||'Custom';
    const sz=zoom?52:42, isz=zoom?40:32;
    
    const html=`
    <div class="dh">
      <div>
        <div class="dht" style="color:var(--b); font-size:18px">${l.nm} <span style="font-size:12px;color:var(--t2);font-weight:700">· Chạy trên ${l.models.length} chuyền · ${pl}</span></div>
        <div style="display:flex;align-items:center;gap:6px;margin-top:3px">
          <span style="width:7px;height:7px;border-radius:50%;background:${l.statusCol};display:inline-block"></span>
          <span style="font-size:11px;color:${l.statusCol};font-weight:800">${l.statusTxt}${l.reason?' — '+l.reason:''}</span>
        </div>
      </div>
      ${!zoom?`<button class="bz" onclick="openZ()">⛶ Expand</button>`:''}
    </div>

    <div class="dstats">
      <div class="dsi"><div class="dsl">Total Target</div><div class="dsv" style="color:var(--b)">${l.tot_t.toLocaleString()}</div></div>
      <div class="dsi"><div class="dsl">Total Actual</div><div class="dsv" style="color:${bc}">${l.tot_a.toLocaleString()}</div></div>
      <div class="dsi"><div class="dsl">Performance</div>${donut(pctW,bc,sz,isz)}</div>
      <div class="dsi"><div class="dsl">OEE</div>${donut(oee,'var(--b)',sz,isz)}</div>
      <div class="dsi"><div class="dsl">FPY</div>${donut(fpy,'var(--g)',sz,isz)}</div>
      <div class="dsi"><div class="dsl">Downtime</div><div class="dsv" style="color:var(--r);font-size:14px">${fmtT(l.tot_s)}</div></div>
    </div>

    <div class="mstrip">
      <div class="mstrip-lbl">Các chuyền (Lines) đang chạy ${l.nm} — Click để xem biểu đồ</div>
      <div class="mstrip-row">
        ${l.models.map(m=>{
          const mp=m.target>0?Math.round(m.actual/m.target*100):0;
          const mbc=mp>=90?'#10b981':mp>=75?'#f59e0b':'#ef4444';
          const sel=selModel?.id===m.id?'sel':'';
          return`<div class="mc ${sel}" onclick="pickModel('${m.id}','${pfx}')" style="border-left: 4px solid ${mbc}; min-width:130px">
            <div class="mc-nm" title="${m.model}" style="font-size:13px">${m.model}</div>
            <div class="mc-sub" style="font-size:10px; color:var(--b); margin-bottom:4px">WO: ${m.workOrder || 'N/A'}</div>
            <div style="display:flex; justify-content:space-between; font-weight:800; font-size:10px; color:var(--t2)">
              <span>Target:</span><span>${m.target.toLocaleString()}</span>
            </div>
            <div style="display:flex; justify-content:space-between; font-weight:800; font-size:11px; color:${mbc}; margin-top:2px">
              <span>Actual:</span><span>${m.actual.toLocaleString()}</span>
            </div>
            <div class="mc-bar" style="margin-top:6px"><div class="mc-barf" style="width:${Math.min(mp,100)}%;background:${mbc}"></div></div>
          </div>`;
        }).join('')}
      </div>
    </div>

    <div class="tabs">
      <div class="tab ${curTab==='today'?'on':''}" onclick="swTab('today','${pfx}')">Today (8h–7h59)</div>
      <div class="tab ${curTab==='7days'?'on':''}" onclick="swTab('7days','${pfx}')">Last 7 Days</div>
      <div class="tab ${curTab==='30days'?'on':''}" onclick="swTab('30days','${pfx}')">Last 30 Days</div>
      <div class="tab ${curTab==='ytd'?'on':''}" onclick="swTab('ytd','${pfx}')">YTD</div>
    </div>

    <div class="ca">
      <div class="cr">
        <div class="cb">
          <div class="ct">Output Trend — Chuyền ${selModel?.model||'All'}</div>
          <div style="position:relative;flex:1;min-height:0"><canvas id="${pfx}dc1"></canvas></div>
        </div>
        <div class="cb">
          <div class="ct">OEE &amp; Performance Trend — ${l.nm}</div>
          <div style="position:relative;flex:1;min-height:0"><canvas id="${pfx}dc2"></canvas></div>
        </div>
      </div>
      <div class="cr">
        <div class="cb">
          <div class="ct">FPY Quality Trend — Chuyền ${selModel?.model||''}</div>
          <div style="position:relative;flex:1;min-height:0"><canvas id="${pfx}dc3"></canvas></div>
        </div>
        <div class="cb">
          <div class="ct">So sánh Sản Lượng Các Chuyền — ${l.nm}</div>
          <div style="position:relative;flex:1;min-height:0"><canvas id="${pfx}dc4"></canvas></div>
        </div>
      </div>
    </div>`;
    
    if(zoom){ document.getElementById('zh').innerHTML=html; }
    else     { document.getElementById('rd').innerHTML=html; }

    setTimeout(()=>renderCharts(l,pfx,oee,fpy), 60);
}

function pickModel(mid,pfx){ selModel=selLine?.models.find(m=>m.id===mid)||null; renderDetail(pfx==='z'); }
function swTab(t,pfx){ curTab=t; renderDetail(pfx==='z'); }

function renderCharts(l,pfx,oee,fpy){
    const lbl=curTab==='today'?['08','10','12','14','16','18','20','22','00','02','04','06']:
              curTab==='7days'?['Mon','Tue','Wed','Thu','Fri','Sat','Sun']:
              curTab==='30days'?Array.from({length:15},(_,i)=>(i*2+1)+''):
              ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
              
    const n=lbl.length;
    const m=selModel||l.models[0];
    const tA=m.actual/n, tT=m.target/n;

    [`${pfx}dc1`,`${pfx}dc2`,`${pfx}dc3`,`${pfx}dc4`].forEach(id=>{const c=Chart.getChart(id);if(c)c.destroy();});

    const bo={responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false}},
      scales:{x:{grid:{display:false},ticks:{font:{size:9}}},
              y:{beginAtZero:true,ticks:{font:{size:9}},grid:{color:'rgba(0,0,0,.05)'}}}};
              
    // Chart 1: Output Trend
    new Chart(document.getElementById(`${pfx}dc1`),{type:'bar',data:{labels:lbl,datasets:[
        {label:'Actual',data:Array.from({length:n},()=>Math.round(tA*.6+Math.random()*tA*1.2)),backgroundColor:'#10b981',borderRadius:2},
        {label:'Target',data:Array(n).fill(Math.round(tT)),type:'line',borderColor:'#ef4444',borderDash:[4,4],borderWidth:1.5,pointRadius:0}
    ]},options:bo});
    
    // Chart 2: OEE & Performance
    const perfPct=m.target>0?m.actual/m.target*100:0;
    new Chart(document.getElementById(`${pfx}dc2`),{type:'line',data:{labels:lbl,datasets:[
        {label:'OEE%',   data:Array.from({length:n},()=>Math.min(100,Math.max(0,oee+(Math.random()*14-7)))),borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,.08)',fill:true,tension:.35,pointRadius:2,borderWidth:2},
        {label:'Perf%',  data:Array.from({length:n},()=>Math.min(100,Math.max(0,perfPct+(Math.random()*12-6)))),borderColor:'#10b981',tension:.35,pointRadius:0,borderWidth:1.5,borderDash:[3,3]},
    ]},options:{...bo,scales:{...bo.scales,y:{min:0,max:100,ticks:{font:{size:9}},grid:{color:'rgba(0,0,0,.05)'}}}}});
    
    // Chart 3: FPY Trend
    new Chart(document.getElementById(`${pfx}dc3`),{type:'line',data:{labels:lbl,datasets:[
        {label:'FPY%',data:Array.from({length:n},()=>Math.min(100,Math.max(85,fpy+(Math.random()*8-4)))),borderColor:'#10b981',backgroundColor:'rgba(16,185,129,.08)',fill:true,tension:.2,pointRadius:2,borderWidth:2,stepped:true},
    ]},options:{...bo,scales:{...bo.scales,y:{min:80,max:100,ticks:{font:{size:9}},grid:{color:'rgba(0,0,0,.05)'}}}}});
    
    // Chart 4: Model Comparison (horizontal bar)
    const selId=selModel?.id;
    new Chart(document.getElementById(`${pfx}dc4`),{type:'bar',
      data:{labels:l.models.map(m=>m.model),
            datasets:[
              {label:'Actual',data:l.models.map(m=>m.actual),backgroundColor:l.models.map(m=>m.id===selId?'#3b82f6':'#10b981'),borderRadius:2},
              {label:'Target',data:l.models.map(m=>m.target),backgroundColor:'#e2e8f0',borderRadius:2},
            ]},
      options:{...bo,indexAxis:'y',
        scales:{x:{beginAtZero:true,ticks:{font:{size:9}},grid:{color:'rgba(0,0,0,.05)'}},
                y:{grid:{display:false},ticks:{font:{size:9}}}}}});
}

function openZ(){
    isZoom=true;
    const m=document.getElementById('zmod');
    m.style.display='flex';
    requestAnimationFrame(()=>m.style.opacity='1');
    renderDetail(true);
}
function closeZ(){
    isZoom=false;
    const m=document.getElementById('zmod');
    m.style.opacity='0';
    setTimeout(()=>{m.style.display='none'; renderDetail(false);},200);
}

// ────────────────────────────────────────────────────────────────
// 8. MIDDLE CHARTS (YTD Tự Động Gom Tháng)
// ────────────────────────────────────────────────────────────────
let ytdI=null, parI=null;

function renderMid(){
    const ctx=document.getElementById('ytdC');
    if(ytdI)ytdI.destroy();
    
    // Khởi tạo mảng 12 tháng
    const monthlyActual = Array(12).fill(0);
    const monthlyTarget = Array(12).fill(0);

    // Gom dữ liệu từ rawPD theo tháng
    rawPD.forEach(r => {
        if (r.date) {
            const month = parseInt(r.date.split('-')[1], 10) - 1; // 0-11
            if (month >= 0 && month <= 11) {
                monthlyActual[month] += (r.actual || 0);
                monthlyTarget[month] += (r.target || 0);
            }
        }
    });

    // Nếu có thực tế mà KHÔNG CÓ target (trường hợp quên nhập excel), tự động gán target mồi để chart đỡ xấu
    for(let i=0; i<12; i++) {
        if(monthlyTarget[i] === 0 && monthlyActual[i] > 0) monthlyTarget[i] = monthlyActual[i] + 5000;
    }

    ytdI=new Chart(ctx,{type:'bar',data:{
        labels:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
        datasets:[
            {label:'Actual', data:monthlyActual, backgroundColor:'#10b981',borderRadius:3},
            {label:'Target', data:monthlyTarget, backgroundColor:'#e2e8f0',borderRadius:3}
        ]},
        options:{responsive:true,maintainAspectRatio:false,
            plugins:{legend:{position:'bottom',labels:{boxWidth:10,font:{size:10}}}},
            scales:{x:{grid:{display:false},ticks:{font:{size:9}}},y:{ticks:{font:{size:9}},grid:{color:'rgba(0,0,0,.05)'}}}
        }});

    const cp=document.getElementById('parC');
    if(parI)parI.destroy();
    const def=[{r:'Cosmetic',n:145},{r:'Dimension',n:82},{r:'Assembly',n:46},{r:'Missing',n:18},{r:'Other',n:9}];
    const tt=def.reduce((a,d)=>a+d.n,0); let cs=0;
    parI=new Chart(cp,{type:'bar',data:{
        labels:def.map(d=>d.r),
        datasets:[
            {label:'Cum%', data:def.map(d=>{cs+=d.n;return+(cs/tt*100).toFixed(1);}),type:'line',borderColor:'#f59e0b',yAxisID:'y1',borderWidth:2,pointRadius:3},
            {label:'Count',data:def.map(d=>d.n),backgroundColor:'#ef4444',borderRadius:3,yAxisID:'y'}
        ]},
        options:{responsive:true,maintainAspectRatio:false,
            plugins:{legend:{display:false}},
            scales:{x:{grid:{display:false},ticks:{font:{size:9}}},
                    y:{ticks:{font:{size:9}}},
                    y1:{position:'right',min:0,max:100,grid:{display:false},ticks:{font:{size:9},callback:v=>v+'%'}}}
        }});
}

// ────────────────────────────────────────────────────────────────
// 9. INIT & AUTO FETCH API
// ────────────────────────────────────────────────────────────────
async function fetchProductionData() {
    const fs = document.getElementById('file-status');
    try {
        const response = await fetch('/Kpi/GetProductionData'); 
        if (!response.ok) throw new Error('Mất kết nối tới Server!');
        
        const res = await response.json();
        const isError = res.isError;
        const data = res.data;
        
        // 1. CẬP NHẬT TRẠNG THÁI NÚT NGAY LẬP TỨC (Không cần biết có data hay không)
        if(fs) {
            if(isError) {
                fs.style.background = 'var(--r)'; // Đỏ
                fs.style.color = '#fff';
                fs.textContent = '⚠ Error (Fake Data)';
            } else {
                fs.style.background = 'var(--g)'; // Xanh
                fs.style.color = '#fff';
                fs.textContent = 'Live';
            }
        }
        
        const timeTag = document.getElementById('last-upd');
        if(timeTag) {
            const now = new Date();
            timeTag.textContent = `Last update: ${now.getHours().toString().padStart(2,'0')}:${now.getMinutes().toString().padStart(2,'0')}`;
        }

        // 2. VẼ BIỂU ĐỒ NẾU CÓ DATA
        if (data && data.length > 0) {
            rawPD = data; 
            BASE = buildBaseLines(rawPD).map(enrichLine); 
            
            PER.day = BASE;
            PER.week = mkPeriod(BASE, 5, 5, 5);
            PER.month = mkPeriod(BASE, 22, 21, 21);
            PER.ytd = mkPeriod(BASE, 80, 78, 78);

            if (curP === 'day') curLines = [...BASE];
            else sp(curP); 
            
            filt(); 
            renderMid();
        } else {
            // NẾU DATA RỖNG THÌ HIỆN CHỮ NÀY THAY VÌ TREO
            document.getElementById('rd').innerHTML=`<div style="height:100%;display:flex;align-items:center;justify-content:center;color:var(--t3);font-size:14px;font-weight:800">Không có dữ liệu trả về!</div>`;
        }
    } catch (error) {
        console.error("Lỗi lấy dữ liệu:", error);
        if(fs) {
            fs.style.background = 'var(--r)';
            fs.style.color = '#fff';
            fs.textContent = '⚠ Mất kết nối API';
        }
    }
}
</script>
