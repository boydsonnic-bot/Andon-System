@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Production KPI Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
/* 100vh lock to prevent full page scroll */
body{font-family:'Nunito', system-ui, sans-serif; font-size:13px; background:#f1f5f9; color:#0f172a; height:100vh; overflow:hidden}

:root{
  --bg-primary:#ffffff;--bg-secondary:#f8fafc;--bg-tertiary:#e2e8f0;
  --text-primary:#0f172a;--text-secondary:#475569;--text-tertiary:#94a3b8;
  --border:#e2e8f0;
  --radius-md:8px;--radius-lg:12px;
  --green:#10b981;--yellow:#f59e0b;--red:#ef4444;--blue:#3b82f6;--purple:#8b5cf6;--orange:#f97316;
}
#app{max-width:1600px;margin:0 auto;padding:10px 14px;height:100%;display:flex;flex-direction:column;gap:10px}

/* ================= HEADER ================= */
.hdr{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;background:var(--bg-primary);padding:8px 16px;border-radius:var(--radius-lg);border:1px solid var(--border)}
.hdr-title{font-size:16px;font-weight:900;color:var(--text-primary);display:flex;align-items:center;gap:8px}
.hdr-dot{width:8px;height:8px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
.hdr-time{font-size:13px;color:var(--text-secondary);font-weight:800}

/* ================= TOP KPI ================= */
.kpi-row{flex-shrink:0;display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:8px}
.kpi-card{background:var(--bg-primary);border-radius:var(--radius-lg);padding:8px 12px;border:1px solid var(--border);border-left:4px solid;display:flex;flex-direction:column;justify-content:center}
.kpi-lbl{font-size:10px;font-weight:800;color:var(--text-secondary);text-transform:uppercase;margin-bottom:2px}
.kpi-val{font-size:20px;font-weight:900;line-height:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.kpi-sub{font-size:10px;color:var(--text-tertiary);margin-top:2px;font-weight:700}

/* ================= CONTROLS ================= */
.ctrl-row{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:10px}
.ctrl-group{display:flex;align-items:center;gap:6px;background:var(--bg-primary);padding:4px 8px;border-radius:9999px;border:1px solid var(--border)}
.search-box{border:none;outline:none;font-size:12px;padding:2px 6px;width:140px;background:transparent;font-family:'Nunito',sans-serif;font-weight:700}
.date-box{border:none;outline:none;font-size:11px;padding:2px;background:transparent;color:var(--text-primary);font-family:inherit;font-weight:700}
.btn-filter{background:var(--blue);color:#fff;border:none;border-radius:9999px;padding:4px 12px;font-size:11px;font-weight:800;cursor:pointer}

.period-btns{display:flex;gap:4px}
.pb{padding:4px 12px;border-radius:9999px;cursor:pointer;font-size:12px;font-weight:800;border:1px solid var(--border);background:#fff;color:var(--text-secondary);font-family:inherit}
.pb.on{background:var(--blue);color:#fff;border-color:var(--blue)}
.sort-select{padding:4px 10px;border-radius:9999px;cursor:pointer;font-size:12px;font-weight:800;border:1px solid var(--border);background:#fff;color:var(--text-primary);outline:none;font-family:inherit}

/* ================= MIDDLE CHARTS ================= */
.middle-row { flex-shrink: 0; display: flex; gap: 10px; height: 180px; } 
.panel-box { background: var(--bg-primary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 10px 14px; display: flex; flex-direction: column; min-height: 0;}
.panel-title { font-size: 12px; font-weight: 800; color: var(--text-primary); text-transform: uppercase; margin-bottom: 6px; flex-shrink: 0;}
.chart-wrapper { flex: 1; position: relative; min-height: 0; width: 100%; height: 100%; }

/* ================= BOTTOM SPLIT (1/4 & 3/4) ================= */
.bottom-split { flex: 1; min-height: 0; display: flex; gap: 10px; }

/* Left List (1/4) */
.left-list { flex: 0 0 24%; overflow-y: auto; display: flex; flex-direction: column; gap: 8px; padding-right: 4px; }
.left-list::-webkit-scrollbar { width: 4px; }
.left-list::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }

.mini-lc { flex-shrink: 0; background: var(--bg-primary); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 10px; cursor: pointer; transition: 0.15s;}
.mini-lc.active { border-color: var(--blue); box-shadow: 0 0 0 1px var(--blue); background: #f8fafc; }
.mini-nm { font-size: 13px; font-weight: 900; color: var(--text-primary); margin-bottom: 8px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.mini-hbar-wrap { display: flex; flex-direction: column; gap: 4px; }
.mini-hbar { height: 5px; background: var(--bg-tertiary); border-radius: 3px; position: relative; }
.mini-hbar-fill { height: 100%; border-radius: 3px; transition: width 0.5s ease; }
.mini-lbl { display:flex; justify-content: space-between; font-size: 9px; font-weight: 800; color: var(--text-secondary); margin-bottom: 1px;}

/* Right Detail (3/4) - Strictly Fitted */
.right-detail { flex: 1; background: var(--bg-primary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 12px 16px; display: flex; flex-direction: column; min-height: 0; overflow: hidden; }

.detail-header { flex-shrink: 0; display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 8px; border-bottom: 1px solid #f1f5f9; padding-bottom: 8px;}
.detail-title { font-size: 16px; font-weight: 900; color: var(--text-primary); }

.detail-stats-row { flex-shrink: 0; display: grid; grid-template-columns: repeat(6, 1fr); gap: 6px; margin-bottom: 10px; background: var(--bg-secondary); padding: 8px; border-radius: var(--radius-md); border: 1px solid #f1f5f9;}
.d-stat-box { display: flex; flex-direction: column; align-items: center; justify-content: center; }
.d-val-txt { font-size: 18px; font-weight: 900; line-height: 1.2; }
.d-lbl-txt { font-size: 9px; font-weight: 800; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 4px; text-align:center; }
.d-chart { width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 2px; }
.d-inner { width: 34px; height: 34px; background: var(--bg-secondary); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 900; }

.prod-modal-tabs { flex-shrink: 0; display:flex; border-bottom:1px solid var(--border); margin-bottom:8px}
.prod-modal-tab { padding:4px 16px; cursor:pointer; font-size:12px; font-weight:800; border-bottom:2px solid transparent; color:var(--text-secondary);}
.prod-modal-tab.on { border-bottom-color:var(--blue); color:var(--blue)}

#detail-chart-area { flex: 1; display: flex; flex-direction: column; gap: 8px; min-height: 0; }
.dc-row { display: flex; gap: 8px; flex: 1; min-height: 0; }
.dc-box { flex: 1; border: 1px solid var(--border); border-radius: var(--radius-md); padding: 8px 12px; display: flex; flex-direction: column; min-height: 0; }
.dc-title { font-size: 10px; font-weight: 800; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 6px; flex-shrink: 0; }

.btn-zoom { background: var(--bg-secondary); border: 1px solid var(--border); color: var(--text-primary); cursor: pointer; padding: 4px 10px; border-radius: 6px; font-size: 12px; font-weight: 900; display: flex; align-items: center; gap: 4px; font-family:inherit; outline:none}
.btn-zoom:hover { background: var(--blue); color: #fff; border-color: var(--blue); }

/* ================= INDEPENDENT ZOOM MODAL ================= */
#zoomModal { display:none; opacity:0; position:fixed; inset:0; background:rgba(15,23,42,0.85); z-index:9999; align-items:center; justify-content:center; padding:20px; transition:opacity 0.2s;}
.zm-content { background:#fff; border-radius:16px; width:95vw; height:90vh; display:flex; flex-direction:column; padding:20px; position:relative; box-shadow:0 25px 50px -12px rgba(0,0,0,0.5); }
.zm-close { position:absolute; top:16px; right:16px; width:32px; height:32px; border:none; border-radius:8px; background:#f1f5f9; cursor:pointer; font-size:16px; font-weight:900; color:#64748b; font-family:inherit}
</style>
</head>
<body>
<div id="app">

  <div class="hdr">
    <div class="hdr-title"><span class="hdr-dot"></span> PRODUCTION KPI DASHBOARD</div>
    <div style="display:flex;align-items:center;gap:12px">
      <span class="hdr-time" id="clock"></span>
      <button onclick="toggleFS()" style="background:var(--bg-secondary);border:1px solid var(--border);color:var(--text-primary);cursor:pointer;padding:4px 10px;border-radius:6px;font-size:12px;font-weight:800;font-family:inherit">⛶ Fullscreen</button>
    </div>
  </div>

  <div class="kpi-row" id="kpi-row"></div>

  <div class="ctrl-row">
    <div style="display:flex; align-items:center; gap:8px;">
      <div class="ctrl-group">
        <span style="font-size:12px; margin-left:4px">🔍</span>
        <input type="text" id="searchBox" class="search-box" placeholder="Search Model..." onkeyup="filterAndSortData()">
      </div>
      <div class="ctrl-group">
        <span style="font-size:10px;color:var(--text-secondary);margin-left:4px;font-weight:800">FROM</span>
        <input type="date" id="dateFrom" class="date-box">
        <span style="font-size:10px;color:var(--text-secondary);font-weight:800">TO</span>
        <input type="date" id="dateTo" class="date-box">
        <button class="btn-filter" onclick="applyDateFilter()">Filter</button>
      </div>
    </div>

    <div style="display:flex; align-items:center; gap: 6px;">
      <select id="sortSelect" class="sort-select" onchange="filterAndSortData()">
        <option value="line_asc">▼ Sort by Model (A-Z)</option>
        <option value="line_desc">▲ Sort by Model (Z-A)</option>
        <option value="kpi_desc">▼ Performance (High to Low)</option>
        <option value="kpi_asc">▲ Performance (Low to High)</option>
      </select>
      <div class="period-btns">
        <button onclick="switchPeriod('day')"   id="period-day"   class="pb on">Today</button>
        <button onclick="switchPeriod('week')"  id="period-week"  class="pb">This Week</button>
        <button onclick="switchPeriod('month')" id="period-month" class="pb">This Month</button>
        <button onclick="switchPeriod('ytd')"   id="period-ytd"   class="pb">YTD</button>
      </div>
    </div>
  </div>

  <div class="middle-row">
    <div class="panel-box" style="flex: 2.2;">
      <div class="panel-title">📊 Yearly Production Output (YTD)</div>
      <div class="chart-wrapper"><canvas id="ytdChart"></canvas></div>
    </div>
    <div class="panel-box" style="flex: 1;">
      <div class="panel-title">📉 Top Quality Issues (Pareto 80/20)</div>
      <div class="chart-wrapper"><canvas id="paretoChart"></canvas></div>
    </div>
  </div>

  <div class="bottom-split">
    <div class="left-list" id="left-list"></div>

    <div class="right-detail" id="right-detail">
      <div style="display:flex; height:100%; align-items:center; justify-content:center; color:var(--text-tertiary); font-size:16px; font-weight:800">
        Loading Details...
      </div>
    </div>
  </div>

</div>

<div id="zoomModal" onclick="if(event.target===this)closeZoomModal()">
  <div class="zm-content">
    <button onclick="closeZoomModal()" class="zm-close">✕</button>
    <div id="zoom-header" class="detail-header" style="margin-bottom:20px; padding-bottom:16px"></div>
    <div id="zoom-stats" class="detail-stats-row" style="margin-bottom:20px"></div>
    <div class="prod-modal-tabs" id="zoom-tabs"></div>
    <div id="zoom-chart-area" style="flex:1; display:flex; flex-direction:column; gap:16px; min-height:0"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
// ============================================================
// 1. DATA INITIALIZATION
// ============================================================
let rawPD = [];
try { rawPD = JSON.parse('@Html.Raw(ViewBag.ProductionData)' || '[]'); } catch(e) {}

if (!rawPD || rawPD.length === 0) {
    const models = ['MODEL-X-2026','MODEL-Y-2026','MODEL-Z-2026','MODEL-A-2026','MODEL-B-2026','MODEL-C-2026','MODEL-D-2026','MODEL-E-2026','MODEL-F-2026','MODEL-G-2026','MODEL-H-2026'];
    rawPD = Array.from({length:11}, (_,i) => {
        const tgt = 1500; 
        const act = Math.floor(tgt*(0.70+Math.random()*0.25));
        return { id:`M${(i+1)}`, model:models[i], target:tgt, actual:act, stopMin: Math.floor(Math.random() * 60) };
    });
}

let PD = rawPD.map((p, i) => ({
    _uid: 'U' + i, id: p.id || p.Id || "M00", model: p.model || p.Model || "Unknown Model",
    target: Number(p.target ?? p.Target ?? 0), actual: Number(p.actual ?? p.Actual ?? 0), 
    mrb: Number(p.mrb ?? p.Mrb ?? 0), stopMin: p.stopMin || Math.floor(Math.random() * 60)
}));
PD.forEach(p => { p.mrb = +(((p.actual / Math.max(1, new Date().getHours()-8)) * 0.02 + Math.random()*2)).toFixed(1); });

let PERIOD_DATA = {
    day:   PD,
    week:  PD.map(l=>({...l,target:l.target*5,  actual:l.actual*5, stopMin:l.stopMin*5})),
    month: PD.map(l=>({...l,target:l.target*22, actual:l.actual*21, stopMin:l.stopMin*21})),
    ytd:   PD.map(l=>({...l,target:l.target*80, actual:l.actual*78, stopMin:l.stopMin*78}))
};

let curPeriod = 'day';
let curData   = [...PERIOD_DATA.day];
let displayedData = [...curData];
let selectedUid = null; 
let curTab = 'today';
let isZoomOpen = false;

Chart.defaults.font.family = "'Nunito', system-ui, sans-serif";

function clock(){ document.getElementById('clock').textContent = new Date().toLocaleString('en-US',{weekday:'short',day:'2-digit',month:'short',hour:'2-digit',minute:'2-digit',second:'2-digit',hour12:false}); }

function formatTime(minutes) {
    if (!minutes || minutes <= 0) return '0m';
    let mo = Math.floor(minutes / 43200);
    let d = Math.floor((minutes % 43200) / 1440);
    let h = Math.floor((minutes % 1440) / 60);
    let m = Math.floor(minutes % 60);
    
    let res = [];
    if (mo > 0) res.push(mo + 'mo');
    if (d > 0) res.push(d + 'd');
    if (h > 0) res.push(h + 'h');
    if (m > 0 || res.length === 0) res.push(m + 'm');
    
    return res.join(' ');
}

// ============================================================
// 2. FILTER & SORT
// ============================================================
function filterAndSortData() {
    try {
        const searchTxt = document.getElementById('searchBox').value.toLowerCase();
        const sortVal = document.getElementById('sortSelect').value;

        displayedData = curData.filter(line => line.model.toLowerCase().includes(searchTxt));
        displayedData.sort((a, b) => {
            const pctA = a.target > 0 ? (a.actual / a.target) : 0;
            const pctB = b.target > 0 ? (b.actual / b.target) : 0;
            if (sortVal === 'line_asc')  return a.model.localeCompare(b.model);
            if (sortVal === 'line_desc') return b.model.localeCompare(a.model);
            if (sortVal === 'kpi_asc')   return pctA - pctB;      
            if (sortVal === 'kpi_desc')  return pctB - pctA;      
            return 0;
        });

        renderKPI();
        renderMiniGrid();
        
        if(displayedData.length > 0) {
            if(!displayedData.find(l => l._uid === selectedUid)) showDetail(displayedData[0]._uid);
            else showDetail(selectedUid);
        } else {
            document.getElementById('right-detail').innerHTML = `<div style="display:flex; height:100%; align-items:center; justify-content:center; color:var(--text-tertiary); font-size:16px; font-weight:800">No Models Found</div>`;
        }
    } catch(e) {}
}

function applyDateFilter() {
    const fromDate = document.getElementById('dateFrom').value;
    const toDate = document.getElementById('dateTo').value;
    if(!fromDate || !toDate) return alert("Please select both 'From' and 'To' dates!");
    if(new Date(fromDate) > new Date(toDate)) return alert("Start date cannot be later than end date!");

    document.querySelectorAll('.pb').forEach(b=>b.classList.remove('on'));
    const days = Math.floor((new Date(toDate) - new Date(fromDate)) / (1000 * 60 * 60 * 24)) + 1;
    const multiplier = days > 0 ? days : 1;
    
    curPeriod = 'custom';
    curData = PD.map(l => ({ ...l, target: l.target * multiplier, actual: Math.round(l.actual * multiplier * (0.8 + Math.random()*0.3)), stopMin: Math.round(l.stopMin * multiplier * (0.5 + Math.random()*1.5)) }));
    filterAndSortData();
}

function switchPeriod(p) {
    curPeriod = p; curData = [...PERIOD_DATA[p]];
    document.querySelectorAll('.pb').forEach(b=>b.classList.remove('on'));
    document.getElementById('period-'+p).classList.add('on');
    document.getElementById('dateFrom').value = ''; document.getElementById('dateTo').value = '';
    filterAndSortData();
}

// ============================================================
// 3. RENDER TOP KPI & MINI GRID
// ============================================================
function renderKPI() {
    const tot   = displayedData.reduce((a,l)=>a+l.target,0);
    const act   = displayedData.reduce((a,l)=>a+l.actual,0);
    const perf  = tot>0?Math.round(act/tot*100):0;
    
    let sumOEE = 0, sumFPY = 0, totStop = 0;
    displayedData.forEach(line => {
        const pctW = Math.min(line.target > 0 ? Math.round((line.actual / line.target) * 100) : 0, 100);
        const fpy = Math.max(0, 100 - (line.mrb || 0));
        totStop += (line.stopMin || 0);
        const shiftMins = 480 * (curPeriod === 'week' ? 5 : curPeriod === 'month' ? 21 : curPeriod === 'ytd' ? 78 : curPeriod === 'custom' ? 1 : 1);
        const avail = Math.max(0, 100 - Math.min(100, Math.round(((line.stopMin || 0) / shiftMins) * 100)));
        sumOEE += Math.round((avail / 100) * (pctW / 100) * (fpy / 100) * 100);
        sumFPY += fpy;
    });
    
    const avgOEE = displayedData.length > 0 ? Math.round(sumOEE / displayedData.length) : 0;
    const avgFPY = displayedData.length > 0 ? (sumFPY / displayedData.length).toFixed(1) : 0;

    const perfCol = perf>=90?'var(--green)':perf>=75?'var(--yellow)':'var(--red)';
    const oeeCol = avgOEE>=85?'var(--blue)':avgOEE>=70?'var(--yellow)':'var(--red)';
    const fpyCol = avgFPY>=95?'var(--green)':avgFPY>=90?'var(--yellow)':'var(--red)';

    let periodLabel = curPeriod === 'custom' ? 'Custom Range' : {day:'Today (from 8:00 AM)',week:'This Week',month:'This Month',ytd:'Year to Date'}[curPeriod];

    document.getElementById('kpi-row').innerHTML = [
        {lbl:'Total Target',     val:tot.toLocaleString('en-US'),  sub:periodLabel, col:'var(--blue)', vc:'var(--text-primary)'},
        {lbl:'Total Actual',     val:act.toLocaleString('en-US'),  sub:`${perf}% of target`, col:'var(--green)', vc:'var(--green)'},
        {lbl:'Overall Performance', val:perf+'%', sub:perf>=90?'On track':perf>=75?'Needs attention':'Below target', col:perfCol, vc:perfCol},
        {lbl:'Average FPY',      val:avgFPY+'%', sub:'First Pass Yield', col:fpyCol, vc:fpyCol},
        {lbl:'Average OEE',      val:avgOEE+'%', sub:'Overall Equip. Effectiveness', col:oeeCol, vc:oeeCol},
        {lbl:'Total Downtime',   val:formatTime(totStop), sub:'Total stoppage time', col:'var(--red)', vc:'var(--red)'}
    ].map(k=>`<div class="kpi-card" style="border-left-color:${k.col}">
        <div class="kpi-lbl">${k.lbl}</div>
        <div class="kpi-val" style="color:${k.vc}">${k.val}</div>
        <div class="kpi-sub">${k.sub}</div>
    </div>`).join('');
}

function renderMiniGrid() {
    const list = document.getElementById('left-list');
    if (displayedData.length === 0) { list.innerHTML = ``; return; }

    list.innerHTML = displayedData.map(line => {
        const tgt = line.target || 0; const act = line.actual || 0;
        const pct = tgt > 0 ? Math.round((act / tgt) * 100) : 0; const pctW = Math.min(pct,100);
        const barcol = pct>=90?'var(--green)':pct>=75?'var(--yellow)':'var(--red)';
        const activeCls = (line._uid === selectedUid) ? 'active' : '';

        return `
        <div class="mini-lc ${activeCls}" onclick="showDetail('${line._uid}')">
            <div class="mini-nm" title="${line.model}">${line.model}</div>
            <div class="mini-hbar-wrap">
                <div class="mini-lbl"><span>Target</span><span>${tgt.toLocaleString()}</span></div>
                <div class="mini-hbar"><div class="mini-hbar-fill" style="width:100%;background:var(--blue)"></div></div>
                <div class="mini-lbl"><span>Actual</span><span style="color:${barcol}">${act.toLocaleString()}</span></div>
                <div class="mini-hbar"><div class="mini-hbar-fill" style="width:${pctW}%;background:${barcol}"></div></div>
            </div>
        </div>`;
    }).join('');
}

// ============================================================
// 4. MODEL DETAIL (RIGHT COLUMN & MODAL ZOOM)
// ============================================================
function openZoomModal() {
    isZoomOpen = true;
    document.getElementById('zoomModal').style.display = 'flex';
    requestAnimationFrame(()=>document.getElementById('zoomModal').style.opacity='1');
    showDetail(selectedUid); 
}

function closeZoomModal() {
    isZoomOpen = false;
    document.getElementById('zoomModal').style.opacity='0';
    setTimeout(()=>{ document.getElementById('zoomModal').style.display='none'; showDetail(selectedUid); }, 200);
}

function generateDetailHTML(line, tgt, act, pct, pctW, barcol, oee, fpy, downPct, isZoom) {
    let periodLabel = curPeriod === 'custom' ? 'Custom Range' : {day:'Today (from 8:00 AM)',week:'This Week',month:'This Month',ytd:'Year to Date'}[curPeriod];
    let prefix = isZoom ? 'z' : '';
    let tSize = isZoom ? '24px' : '16px';
    let vSize = isZoom ? '28px' : '18px';
    let dSize = isZoom ? '64px' : '44px';
    let inSize = isZoom ? '50px' : '34px';

    return `
      <div class="detail-header">
        <div style="display:flex; align-items:center; gap:12px">
          <div class="detail-title" style="font-size:${tSize}">${line.model}</div>
          <div style="font-size:11px;color:var(--text-secondary);font-weight:700">${periodLabel}</div>
        </div>
        ${!isZoom ? `<button onclick="openZoomModal()" class="btn-zoom" title="Zoom In">⛶ Expand</button>` : ''}
      </div>
      
      <div class="detail-stats-row">
        <div class="d-stat-box">
            <div class="d-lbl-txt">Total Target</div>
            <div class="d-val-txt" style="color:var(--blue); font-size:${vSize}">${tgt.toLocaleString()}</div>
        </div>
        <div class="d-stat-box">
            <div class="d-lbl-txt">Total Actual</div>
            <div class="d-val-txt" style="color:${barcol}; font-size:${vSize}">${act.toLocaleString()}</div>
        </div>
        <div class="d-stat-box">
            <div class="d-lbl-txt">Performance</div>
            <div class="d-chart" style="width:${dSize};height:${dSize};background:conic-gradient(${barcol} ${pctW}%,var(--bg-primary) 0)"><div class="d-inner" style="width:${inSize};height:${inSize};color:${barcol}">${pct}%</div></div>
        </div>
        <div class="d-stat-box">
            <div class="d-lbl-txt">OEE</div>
            <div class="d-chart" style="width:${dSize};height:${dSize};background:conic-gradient(var(--blue) ${oee}%,var(--bg-primary) 0)"><div class="d-inner" style="width:${inSize};height:${inSize};color:var(--blue)">${oee}%</div></div>
        </div>
        <div class="d-stat-box">
            <div class="d-lbl-txt">FPY</div>
            <div class="d-chart" style="width:${dSize};height:${dSize};background:conic-gradient(var(--green) ${fpy}%,var(--bg-primary) 0)"><div class="d-inner" style="width:${inSize};height:${inSize};color:var(--green)">${fpy.toFixed(0)}%</div></div>
        </div>
        <div class="d-stat-box">
            <div class="d-lbl-txt">Downtime</div>
            <div class="d-chart" style="width:${dSize};height:${dSize};background:conic-gradient(var(--red) ${downPct}%,var(--bg-primary) 0)"><div class="d-inner" style="width:${inSize};height:${inSize};color:var(--red)">${downPct}%</div></div>
        </div>
      </div>

      <div class="prod-modal-tabs">
        <div onclick="switchDetailTab('today')" class="prod-modal-tab ${curTab==='today'?'on':''}">Today (8h-7h59)</div>
        <div onclick="switchDetailTab('7days')" class="prod-modal-tab ${curTab==='7days'?'on':''}">Last 7 Days</div>
        <div onclick="switchDetailTab('30days')" class="prod-modal-tab ${curTab==='30days'?'on':''}">Last 30 Days</div>
        <div onclick="switchDetailTab('ytd')" class="prod-modal-tab ${curTab==='ytd'?'on':''}">YTD</div>
      </div>

      <div id="${prefix}detail-chart-area" style="flex: 1; display: flex; flex-direction: column; gap: 8px; min-height: 0;">
          <div class="dc-row">
            <div class="dc-box">
                <div class="dc-title">Output Trend (Actual vs Target)</div>
                <div class="chart-wrapper"><canvas id="${prefix}dc1"></canvas></div>
            </div>
            <div class="dc-box">
                <div class="dc-title">OEE & Performance Trend</div>
                <div class="chart-wrapper"><canvas id="${prefix}dc2"></canvas></div>
            </div>
          </div>
          <div class="dc-row">
            <div class="dc-box" style="flex:1">
                <div class="dc-title">Quality Trend (First Pass Yield %)</div>
                <div class="chart-wrapper"><canvas id="${prefix}dc3"></canvas></div>
            </div>
          </div>
      </div>
    `;
}

function showDetail(uid) {
    try {
        selectedUid = uid;
        if(!isZoomOpen) renderMiniGrid(); 
        
        const line = displayedData.find(l=>l._uid===uid);
        if (!line) return;
        
        const tgt = line.target || 0; const act = line.actual || 0;
        const pct = tgt > 0 ? Math.round((act / tgt) * 100) : 0; const pctW = Math.min(pct,100);
        const barcol = pct>=90?'var(--green)':pct>=75?'var(--yellow)':'var(--red)';
        
        const fpy = Math.max(0, 100 - (line.mrb || 0));
        const shiftMins = 480 * (curPeriod === 'week' ? 5 : curPeriod === 'month' ? 21 : curPeriod === 'ytd' ? 78 : curPeriod === 'custom' ? 1 : 1);
        const downPct = Math.min(100, Math.round(((line.stopMin||0) / shiftMins) * 100)); 
        const avail = Math.max(0, 100 - downPct);
        const oee = Math.round((avail / 100) * (pctW / 100) * (fpy / 100) * 100);

        if (isZoomOpen) {
            document.getElementById('zoom-header').outerHTML = `<div id="zoom-header">${generateDetailHTML(line, tgt, act, pct, pctW, barcol, oee, fpy, downPct, true)}</div>`;
        } else {
            document.getElementById('right-detail').innerHTML = generateDetailHTML(line, tgt, act, pct, pctW, barcol, oee, fpy, downPct, false);
        }
        
        setTimeout(() => { renderDetailCharts(line, oee, fpy, isZoomOpen); }, 50);
    } catch(e) {}
}

function switchDetailTab(tab) {
    curTab = tab;
    showDetail(selectedUid);
}

function renderDetailCharts(line, currentOee, currentFpy, isZoom) {
    try {
        let labels = [];
        if(curTab==='today') labels = ['08:00','10:00','12:00','14:00','16:00','18:00','20:00','22:00','00:00','02:00','04:00','06:00'];
        else if(curTab==='7days') labels = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
        else if(curTab==='30days') labels = Array.from({length:15},(_,i)=>(i*2+1)+'');
        else labels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        
        const len = labels.length;
        let pfx = isZoom ? 'z' : '';
        [`${pfx}dc1`,`${pfx}dc2`,`${pfx}dc3`].forEach(id=>{ const c=Chart.getChart(id); if(c)c.destroy(); });

        let tgtAvg = line.target / (curTab==='today'?12:1);
        let actAvg = line.actual / (curTab==='today'?12:1);

        new Chart(document.getElementById(`${pfx}dc1`),{type:'bar', data:{labels,datasets:[ {label:'Actual',data:Array.from({length:len},()=>Math.round(actAvg*.7+Math.random()*actAvg*.6)),backgroundColor:'#10b981',borderRadius:3}, {label:'Target',data:Array(len).fill(Math.round(tgtAvg)),type:'line',borderColor:'#ef4444',borderDash:[4,4],borderWidth:2,pointRadius:0} ]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{beginAtZero:true}}}});
        new Chart(document.getElementById(`${pfx}dc2`),{type:'line', data:{labels,datasets:[ {label:'OEE %',data:Array.from({length:len},()=>Math.min(100, Math.max(0, currentOee + (Math.random()*16-8)))),borderColor:'#3b82f6',backgroundColor:'rgba(59,130,246,0.1)',tension:.4,pointRadius:2,borderWidth:2,fill:true} ]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{min:0, max:100}}}});
        new Chart(document.getElementById(`${pfx}dc3`),{type:'line', data:{labels,datasets:[ {label:'FPY %',data:Array.from({length:len},()=>Math.min(100, Math.max(0, currentFpy + (Math.random()*8-4)))),borderColor:'#10b981',backgroundColor:'rgba(16,185,129,0.1)',tension:.2,pointRadius:3,borderWidth:2,fill:true, stepped: true} ]},options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},scales:{x:{grid:{display:false}},y:{min:0, max:100}}}});
    } catch(e) {}
}

// ============================================================
// 5. MIDDLE CHARTS (YTD & PARETO)
// ============================================================
let ytdChartInst = null; let paretoChartInst = null;
function renderMiddleCharts() {
    try {
        const ctxYtd = document.getElementById('ytdChart');
        if(ctxYtd) {
            const labels = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
            const target = [250000, 240000, 260000, 250000, 270000, 250000, 260000, 260000, 250000, 270000, 260000, 250000];
            const totAct = PERIOD_DATA.day.reduce((a,l)=>a+l.actual,0) * 22; 
            const actual = [245000, 235000, totAct, 0, 0, 0, 0, 0, 0, 0, 0, 0];
            if(ytdChartInst) ytdChartInst.destroy();
            ytdChartInst = new Chart(ctxYtd, { type: 'bar', data: { labels: labels, datasets: [ { label: 'Actual Output', data: actual, backgroundColor: '#10b981', borderRadius: 4 }, { label: 'Target Output', data: target, backgroundColor: '#cbd5e1', borderRadius: 4 } ] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: {family: 'Nunito', size: 10, weight: 'bold'} } } }, scales: { x: { grid: { display: false }, ticks: { font: { family: 'Nunito', size: 10, weight: 'bold' } } }, y: { grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { family: 'Nunito', size: 10, weight: 'bold' } } } } } });
        }

        const ctxPareto = document.getElementById('paretoChart');
        if(ctxPareto) {
            const defectData = [ { reason: 'Cosmetic', count: 145 }, { reason: 'Dimension', count: 82 }, { reason: 'Assembly', count: 46 }, { reason: 'Missing', count: 18 }, { reason: 'Other', count: 9 } ];
            defectData.sort((a,b) => b.count - a.count);
            const total = defectData.reduce((sum, item) => sum + item.count, 0);
            let cumSum = 0; const labelsP = []; const counts = []; const cumulative = [];
            defectData.forEach(item => { labelsP.push(item.reason); counts.push(item.count); cumSum += item.count; cumulative.push((cumSum / total * 100).toFixed(1)); });

            if(paretoChartInst) paretoChartInst.destroy();
            paretoChartInst = new Chart(ctxPareto, { type: 'bar', data: { labels: labelsP, datasets: [ { label: 'Cum %', data: cumulative, type: 'line', borderColor: '#f59e0b', backgroundColor: '#f59e0b', yAxisID: 'y1', borderWidth: 2, pointRadius: 2 }, { label: 'Count', data: counts, backgroundColor: '#ef4444', borderRadius: 4, yAxisID: 'y' } ] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom', labels: { boxWidth: 10, font: {family: 'Nunito', size: 10, weight: 'bold'} } } }, scales: { x: { grid: { display: false }, ticks: { font: { family: 'Nunito', size: 9, weight: 'bold' } } }, y: { type: 'linear', display: true, position: 'left', grid: { color: 'rgba(0,0,0,0.05)' }, ticks: { font: { family: 'Nunito', size: 9, weight: 'bold' } } }, y1: { type: 'linear', display: true, position: 'right', grid: { display: false }, min: 0, max: 100, ticks: { font: { family: 'Nunito', size: 9, weight: 'bold' }, callback: function(val) { return val + '%' } } } } } });
        }
    } catch(e) {}
}

function toggleFS() { if (!document.fullscreenElement) document.documentElement.requestFullscreen().catch(()=>{}); else document.exitFullscreen(); }

window.onload = function() {
    filterAndSortData(); 
    renderMiddleCharts(); 
    clock(); setInterval(clock,1000);
    setInterval(()=>{ filterAndSortData(); renderMiddleCharts(); }, 30000);
};
</script>
</body>
</html>