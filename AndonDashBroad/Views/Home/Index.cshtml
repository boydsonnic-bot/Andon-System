function aTab(t) {
  ['dash','ins','analy'].forEach(x => {
    document.getElementById('tab-'+x).classList.toggle('on', x===t);
    document.getElementById('pg-'+x).classList.toggle('on', x===t);
  });
  if (t === 'ins')   initInsights();
  if (t === 'analy') initAnaly();
}

