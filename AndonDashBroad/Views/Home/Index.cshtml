      options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false}},
        scales:{x:{ticks:{font:{size:10}},grid:{display:false}},y:{ticks:{font:{size:10},stepSize:1},grid:{color:'rgba(128,128,128,0.15)'},beginAtZero:true}}}});
    new Chart(document.getElementById('cl'),{type:'line',
