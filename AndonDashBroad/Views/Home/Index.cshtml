@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>eAndon Dashboard</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,-apple-system,sans-serif;font-size:13px;background:#f0efed;color:#1c1c1a;min-height:100vh}
:root{
  --bg-primary:#ffffff;--bg-secondary:#f5f5f4;--bg-tertiary:#ebebea;
  --text-primary:#1c1c1a;--text-secondary:#5f5e5a;--text-tertiary:#9a9890;
  --border:#e2e1d9;--border-md:#ccc;
  --radius-md:8px;--radius-lg:12px;
  --green:#16a34a;--yellow:#d97706;--red:#dc2626;--orange:#ea580c;--blue:#2563eb;
  --purple:#7c3aed;--teal:#0d9488;
}
@@media(prefers-color-scheme:dark){
  :root{
    --bg-primary:#1e1e1c;--bg-secondary:#272725;--bg-tertiary:#313130;
    --text-primary:#e8e8e2;--text-secondary:#a0a09a;--text-tertiary:#66665e;
    --border:#353533;--border-md:#505050;
  }
  body{background:#141412;color:#e8e8e2}
}
#app{max-width:1280px;margin:0 auto;padding:12px 16px}

/* HEADER */
.hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px}
.hdr-left{display:flex;align-items:center;gap:10px}
.hdr-title{font-size:14px;font-weight:500}
.hdr-live{display:flex;align-items:center;gap:4px;font-size:10px;color:var(--green)}
.hdr-dot{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pulse 2s infinite}
@@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.hdr-time{font-size:11px;color:var(--text-secondary);font-family:monospace}

/* TABS */
.tabs{display:flex;border-bottom:0.5px solid var(--border);margin-bottom:12px}
.tab{padding:6px 14px;border:none;background:none;cursor:pointer;font-size:12px;
     color:var(--text-secondary);border-bottom:2px solid transparent;margin-bottom:-0.5px;
     font-family:inherit;transition:color .15s}
.tab.on{color:var(--text-primary);border-bottom-color:var(--text-primary);font-weight:500}
.tab:hover:not(.on){color:var(--text-primary)}
.page{display:none}.page.on{display:block}

/* DASHBOARD GRID */
.dash-wrap{display:grid;grid-template-columns:minmax(0,1.9fr) minmax(0,1fr) minmax(0,1fr);gap:10px;align-items:start}
@@media(max-width:900px){.dash-wrap{grid-template-columns:1fr}}

/* LINE ROWS */
.lr{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);padding:7px 10px;margin-bottom:5px}
.lrh{display:flex;align-items:center;gap:6px;min-width:0}
.lrd{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.lrn{font-weight:500;font-size:12px;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.lrb{font-size:9px;padding:2px 5px;border-radius:3px;color:#fff;white-space:nowrap;flex-shrink:0;line-height:1.5}
.lrt{font-family:monospace;font-size:11px;color:var(--text-secondary);flex-shrink:0;min-width:40px;text-align:right}
.lrw{display:flex;gap:8px;margin-top:3px;font-size:10px;color:var(--text-secondary)}
.lrwi{display:flex;gap:3px;align-items:center;flex:1;min-width:0;overflow:hidden;white-space:nowrap;text-overflow:ellipsis}
.lrwl{color:var(--text-tertiary);flex-shrink:0}
.lrhi{margin-top:3px;display:flex;gap:4px}
.chip{font-size:10px;padding:1px 6px;border-radius:3px;background:var(--bg-secondary);
      color:var(--text-secondary);border:0.5px solid var(--border);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:160px}

/* STAT PANEL */
.mc{background:var(--bg-secondary);border-radius:var(--radius-md);padding:8px 10px}
.mc-l{font-size:10px;color:var(--text-secondary);margin-bottom:2px}
.mc-v{font-size:19px;font-weight:500}
.stat-box{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);padding:8px 10px}
.sr{display:flex;align-items:center;gap:6px;padding:4px 0;border-bottom:0.5px solid var(--border);font-size:11px}
.sr:last-child{border-bottom:none}
.ab{flex:1;height:3px;background:var(--border);border-radius:2px;overflow:hidden}
.abf{height:100%;border-radius:2px}

/* AI HINT PANEL */
.ai-panel{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);overflow:hidden}
.ai-header{display:flex;align-items:center;gap:6px;padding:8px 10px;border-bottom:0.5px solid var(--border);background:var(--bg-secondary)}
.ai-icon{width:18px;height:18px;border-radius:4px;background:linear-gradient(135deg,#7c3aed,#2563eb);display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ai-icon svg{width:11px;height:11px;fill:#fff}
.ai-title{font-size:11px;font-weight:500}
.ai-badge{font-size:9px;padding:1px 5px;border-radius:10px;background:#7c3aed18;color:#7c3aed;border:0.5px solid #7c3aed40;margin-left:auto}
.hint-list{padding:6px 8px}
.hint{display:flex;gap:7px;padding:5px 4px;border-bottom:0.5px solid var(--border);align-items:flex-start}
.hint:last-child{border-bottom:none}
.hint-ico{width:16px;height:16px;border-radius:3px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:1px}
.hint-ico svg{width:10px;height:10px}
.hint-body{flex:1;min-width:0}
.hint-title{font-size:11px;font-weight:500;line-height:1.4}
.hint-sub{font-size:10px;color:var(--text-secondary);margin-top:1px;line-height:1.4}
.hint-tag{font-size:9px;padding:1px 5px;border-radius:3px;margin-top:3px;display:inline-block}
.hint-critical .hint-ico{background:#dc262618}.hint-critical .hint-ico svg{fill:#dc2626}
.hint-warn .hint-ico{background:#d9770618}.hint-warn .hint-ico svg{fill:#d97706}
.hint-good .hint-ico{background:#16a34a18}.hint-good .hint-ico svg{fill:#16a34a}
.hint-info .hint-ico{background:#2563eb18}.hint-info .hint-ico svg{fill:#2563eb}
.hint-critical .hint-tag{background:#dc262612;color:#dc2626;border:0.5px solid #dc262640}
.hint-warn .hint-tag{background:#d9770612;color:#d97706;border:0.5px solid #d9770640}
.hint-good .hint-tag{background:#16a34a12;color:#16a34a;border:0.5px solid #16a34a40}
.hint-info .hint-tag{background:#2563eb12;color:#2563eb;border:0.5px solid #2563eb40}
.hint-refresh{width:100%;padding:5px;font-size:10px;color:var(--text-tertiary);background:none;
              border:none;border-top:0.5px solid var(--border);cursor:pointer;font-family:inherit}
.hint-refresh:hover{color:var(--text-secondary);background:var(--bg-secondary)}

/* ANALYTICS */
.filter-bar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:10px;align-items:center}
.filter-bar select,.filter-bar input{font-size:12px;padding:3px 7px;border:0.5px solid var(--border-md);
  border-radius:var(--radius-md);background:var(--bg-primary);color:var(--text-primary);height:26px;font-family:inherit}
.filter-bar button{font-size:11px;padding:3px 10px;border:0.5px solid var(--border-md);border-radius:var(--radius-md);
  background:var(--bg-primary);color:var(--text-primary);cursor:pointer;height:26px;font-family:inherit}
.filter-bar button:hover{background:var(--bg-secondary)}
.mg4{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-bottom:10px}
.cg2{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:10px;margin-bottom:10px}
.cg3{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr) minmax(0,1fr);gap:10px;margin-bottom:10px}
.cbox{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);padding:10px;position:relative}
.cbox-label{font-size:10px;color:var(--text-secondary);margin-bottom:6px}

/* INSIGHTS PAGE */
.ins-grid{display:grid;grid-template-columns:minmax(0,2fr) minmax(0,1fr);gap:10px;margin-bottom:10px}
.ins-full{margin-bottom:10px}

/* KPI RIBBON */
.kpi-ribbon{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:8px;margin-bottom:10px}
@@media(max-width:800px){.kpi-ribbon{grid-template-columns:repeat(3,1fr)}}
.kpi{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);padding:8px 10px;position:relative;overflow:hidden}
.kpi::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px}
.kpi-g::before{background:var(--green)}.kpi-r::before{background:var(--red)}
.kpi-y::before{background:var(--yellow)}.kpi-b::before{background:var(--blue)}
.kpi-p::before{background:var(--purple)}.kpi-t::before{background:var(--teal)}
.kpi-l{font-size:9px;color:var(--text-secondary);margin-bottom:3px;padding-left:7px}
.kpi-v{font-size:18px;font-weight:500;padding-left:7px;line-height:1}
.kpi-d{font-size:9px;padding-left:7px;margin-top:2px}

/* HIST TABLE */
.hist-wrap{background:var(--bg-primary);border:0.5px solid var(--border);border-radius:var(--radius-md);overflow:hidden}
.hist-head{padding:6px 10px;border-bottom:0.5px solid var(--border);font-size:12px;font-weight:500;display:flex;justify-content:space-between;align-items:center}
.hist-scroll{overflow-x:auto;overflow-y:auto;max-height:280px}
table{width:100%;border-collapse:collapse}
th{font-weight:500;position:sticky;top:0;background:var(--bg-secondary);z-index:1}
td,th{padding:4px 8px;text-align:left;white-space:nowrap;font-size:11px;border-bottom:0.5px solid var(--border)}
tr:last-child td{border-bottom:none}
tr:hover td{background:var(--bg-secondary)}
.badge{font-size:10px;padding:1px 5px;border-radius:3px}

/* PARETO */
.pareto-row{display:flex;align-items:center;gap:8px;padding:3px 0;border-bottom:0.5px solid var(--border);font-size:11px}
.pareto-row:last-child{border-bottom:none}
.pareto-bar-wrap{flex:1;height:5px;background:var(--bg-tertiary);border-radius:3px;overflow:hidden}
.pareto-bar{height:100%;border-radius:3px;background:var(--blue)}

/* PANEL HEADER + ZOOM BUTTON */
.panel-hdr{display:flex;align-items:center;justify-content:space-between;gap:6px;margin-bottom:6px;min-height:20px}
.panel-hdr-title{font-size:10px;color:var(--text-secondary);flex:1;font-weight:500}
.zoom-btn{display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;
  border:0.5px solid var(--border);border-radius:4px;background:none;cursor:pointer;
  color:var(--text-tertiary);flex-shrink:0;padding:0;font-family:inherit}
.zoom-btn:hover{color:var(--text-primary);background:var(--bg-secondary)}
.zoom-btn svg{width:11px;height:11px;fill:none;stroke:currentColor;stroke-width:2.2px;stroke-linecap:round;stroke-linejoin:round}
</style>
</head>
<body>
<div id="app">

  <!-- HEADER -->
  <div class="hdr">
    <div class="hdr-left">
      <span class="hdr-title">eAndon</span>
      <span class="hdr-live"><span class="hdr-dot"></span>Live</span>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <span class="hdr-time" id="clock"></span>
      <button onclick="toggleFS()" id="btn-fs" title="Toàn màn hình"
        style="background:none;border:0.5px solid var(--border);color:var(--text-secondary);cursor:pointer;
               display:flex;align-items:center;justify-content:center;padding:4px 6px;border-radius:6px;
               gap:4px;font-size:11px;font-family:inherit">
        <svg id="fs-ico" viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
          <path d="M7 14H5v5h5v-2H7v-3zm-2-4h2V7h3V5H5v5zm12 7h-3v2h5v-5h-2v3zM14 5v2h3v3h2V5h-5z"/>
        </svg>
        <span id="fs-lbl">Toàn màn hình</span>
      </button>
    </div>
  </div>

  <!-- TABS -->
  <div class="tabs">
    <button class="tab on" id="tab-dash"  onclick="aTab('dash')">Dashboard</button>
    <button class="tab"    id="tab-ins"   onclick="aTab('ins')">Insights</button>
    <button class="tab"    id="tab-analy" onclick="aTab('analy')">Analytics</button>
  </div>

  <!-- ===================== DASHBOARD ===================== -->
  <div id="pg-dash" class="page on">
    <div class="dash-wrap">

      <!-- COL 1: Line rows -->
      <div>
        <div class="panel-hdr" id="lc-hdr">
          <span class="panel-hdr-title">Trạng thái Lines</span>
        </div>
        <div id="lc"></div>
      </div>

      <!-- COL 2: Stats -->
      <div>
        <div class="panel-hdr" id="sc-hdr">
          <span class="panel-hdr-title">Thống kê ca hiện tại</span>
        </div>
        <div id="sc"></div>
      </div>

      <!-- COL 3: AI Hints -->
      <div class="ai-panel" id="ai-panel">
        <div class="ai-header">
          <div class="ai-icon">
            <svg viewBox="0 0 24 24"><path d="M12 2a2 2 0 012 2c0 .74-.4 1.39-1 1.73V7h1a7 7 0 017 7h1a1 1 0 010 2h-1v1a2 2 0 01-2 2H5a2 2 0 01-2-2v-1H2a1 1 0 010-2h1a7 7 0 017-7h1V5.73c-.6-.34-1-.99-1-1.73a2 2 0 012-2zm0 7a5 5 0 00-5 5v3h10v-3a5 5 0 00-5-5zm-1 4a1 1 0 112 0 1 1 0 01-2 0z"/></svg>
          </div>
          <span class="ai-title">AI Insights</span>
          <span class="ai-badge">Auto</span>
        </div>
        <div class="hint-list" id="hint-list"></div>
        <button class="hint-refresh" onclick="genHints()">↻ Làm mới phân tích</button>
      </div>

    </div>
  </div>

  <!-- ===================== INSIGHTS ===================== -->
  <div id="pg-ins" class="page">
    <div class="kpi-ribbon" id="kpi-ribbon"></div>
    <div class="ins-grid">
      <div class="cbox">
        <div class="cbox-label">Availability theo ngày — 4 tuần gần nhất (%)</div>
        <div style="position:relative;height:180px"><canvas id="c-avail"></canvas></div>
      </div>
      <div class="cbox">
        <div class="cbox-label">Số sự cố theo giờ trong ngày (heatmap)</div>
        <div id="hm-wrap" style="margin-top:4px"></div>
      </div>
    </div>
    <div class="cg2">
      <div class="cbox">
        <div class="cbox-label">MTTR trung bình từng Line — 7 ngày (phút)</div>
        <div style="position:relative;height:170px"><canvas id="c-mttr"></canvas></div>
      </div>
      <div class="cbox">
        <div class="cbox-label">Pareto loại lỗi (80/20)</div>
        <div id="pareto-list" style="margin-top:6px"></div>
      </div>
    </div>
    <div class="cg3">
      <div class="cbox">
        <div class="cbox-label">Hiệu suất KTV (radar)</div>
        <div style="position:relative;height:200px"><canvas id="c-radar"></canvas></div>
      </div>
      <div class="cbox" style="grid-column:span 2">
        <div class="cbox-label">Phân bổ sự cố Vàng / Đỏ theo Line — 7 ngày</div>
        <div style="position:relative;height:200px"><canvas id="c-stack"></canvas></div>
      </div>
    </div>
    <div class="cg2">
      <div class="cbox">
        <div class="cbox-label">MTBF vs MTTR từng Line (scatter)</div>
        <div style="position:relative;height:200px"><canvas id="c-scatter"></canvas></div>
      </div>
      <div class="cbox">
        <div class="cbox-label">Tỷ lệ mức độ sự cố tháng này</div>
        <div style="position:relative;height:180px"><canvas id="c-donut"></canvas></div>
        <div id="donut-legend" style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:6px;font-size:11px"></div>
      </div>
    </div>
  </div>

  <!-- ===================== ANALYTICS ===================== -->
  <div id="pg-analy" class="page">
    <div class="filter-bar">
      <select id="f-line"><option value="">Tất cả Line</option></select>
      <select id="f-stn"><option value="">Tất cả Trạm</option></select>
      <select id="f-shift">
        <option value="">Tất cả Ca</option>
        <option>Ca sáng 6-14h</option><option>Ca chiều 14-22h</option><option>Ca đêm 22-6h</option>
      </select>
      <input type="date" id="f-from">
      <input type="date" id="f-to">
      <input type="text" id="f-wo" placeholder="Work Order..." style="width:110px">
      <button onclick="doFilter()">Lọc</button>
      <button onclick="resetFilter()">Reset</button>
    </div>
    <div class="mg4" id="am"></div>
    <div class="cg2">
      <div class="cbox">
        <div class="cbox-label">Sự cố hôm nay theo Line</div>
        <div style="position:relative;height:160px"><canvas id="cb"></canvas></div>
      </div>
      <div class="cbox">
        <div class="cbox-label">MTTR 7 ngày gần nhất (phút)</div>
        <div style="position:relative;height:160px"><canvas id="cl"></canvas></div>
      </div>
    </div>
    <div class="hist-wrap">
      <div class="hist-head">
        <span>Lịch sử sự cố</span>
        <span id="hist-count" style="font-size:10px;color:var(--text-secondary)"></span>
      </div>
      <div class="hist-scroll">
        <table>
          <thead><tr>
            <th>Thời gian</th><th>Line</th><th>Trạm</th><th>Loại lỗi</th>
            <th>Mức độ</th><th>T.gian</th><th>Báo cáo</th><th>KTV</th><th>Xác nhận</th><th>Work Order</th>
          </tr></thead>
          <tbody id="hb"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.js"></script>
<script>
// ============================================================
// DATA — cắm thẳng từ SQLite qua C# ViewBag
// ============================================================
const rawLiveLines = '@Html.Raw(ViewBag.LiveLines)';
const rawHistory   = '@Html.Raw(ViewBag.HistoryData)';

let LS   = [];
let allH = [];
try {
    LS   = JSON.parse(rawLiveLines && rawLiveLines !== '' ? rawLiveLines : '[]');
    allH = JSON.parse(rawHistory   && rawHistory   !== '' ? rawHistory   : '[]');
} catch (e) {
    console.error("Lỗi đọc Data từ Database:", e);
}

const SC = {
  green:  {c:'#16a34a', lbl:'Bình thường'},
  yellow: {c:'#d97706', lbl:'Chờ KTV'},
  red:    {c:'#dc2626', lbl:'Máy dừng'},
  orange: {c:'#ea580c', lbl:'Đang sửa'},
  blue:   {c:'#2563eb', lbl:'Chờ xác nhận'},
};

// ============================================================
// HELPERS
// ============================================================
const fmtT   = ts  => { if(!ts)return''; const s=Math.floor((Date.now()-ts)/1000),m=Math.floor(s/60),h=Math.floor(m/60); return h>0?h+'h '+(m%60)+'m':m+'m '+(s%60)+'s'; };
const fmtAgo = min => min<60 ? min+'p trước' : Math.floor(min/60)<24 ? Math.floor(min/60)+'h '+(min%60)+'p trước' : Math.floor(min/1440)+' ngày trước';

function clock() {
  document.getElementById('clock').textContent =
    new Date().toLocaleString('vi-VN',{weekday:'short',day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit',second:'2-digit'});
}

// ============================================================
// DASHBOARD — LINE ROWS
// ============================================================
function renderLines() {
  document.getElementById('lc').innerHTML = LS.map(l => {
    const s = SC[l.s], active = l.s !== 'green';
    let who = '', hint = '';
    if (active) {
      const tch = l.tech ? l.tech.nm : '<span style="color:var(--text-tertiary)">Chờ KTV...</span>';
      const ldr = l.lead ? l.lead.nm : '<span style="color:var(--text-tertiary)">—</span>';
      who  = `<div class="lrw">
        <span class="lrwi"><span class="lrwl">Báo:</span>${l.op?l.op.nm:'—'}</span>
        <span class="lrwi"><span class="lrwl">KTV:</span>${tch}</span>
        <span class="lrwi"><span class="lrwl">OK:</span>${ldr}</span>
      </div>`;
      hint = `<div class="lrhi">
        <span class="chip" style="background:${s.c}15;border-color:${s.c}40;color:var(--text-primary)">${l.stn}</span>
        <span class="chip">${l.al}</span>
      </div>`;
    } else if (l.lastErr) {
      const le = l.lastErr;
      who  = `<div class="lrw">
        <span class="lrwi"><span class="lrwl">Lỗi gần nhất:</span>${fmtAgo(le.min)}</span>
        <span class="lrwi"><span class="lrwl">Trạm:</span>${le.st}</span>
        <span class="lrwi"><span class="lrwl">Sửa:</span>${le.dur}m</span>
      </div>`;
      hint = `<div class="lrhi"><span class="chip">${le.al}</span></div>`;
    }
    return `<div class="lr" style="border-left:3px solid ${s.c}">
      <div class="lrh">
        <span class="lrd" style="background:${s.c}"></span>
        <span class="lrn">${l.nm}${active?' — '+l.stn:''}</span>
        <span class="lrb" style="background:${s.c}">${s.lbl}</span>
        ${active?`<span class="lrt" id="ti-${l.id}">${fmtT(l.ts)}</span>`:''}
      </div>${who}${hint}
    </div>`;
  }).join('');
}

// ============================================================
// DASHBOARD — STATS PANEL (grid layout, căn cột chuẩn)
// ============================================================
function renderStats() {
  const act = LS.filter(l=>l.s!=='green').length;
