const ZOOM_TITLES = {
  'lc':        'Trạng thái Lines',
  'sc':        'Thống kê ca hiện tại',
  'ai-panel':  'AI Insights',
  'c-avail':   'Availability theo ngày — 4 tuần gần nhất',
  'c-mttr':    'MTTR trung bình từng Line — 7 ngày',
  'c-radar':   'Hiệu suất KTV (Radar)',
  'c-stack':   'Phân bổ sự cố Vàng / Đỏ theo Line',
  'c-scatter': 'MTBF vs MTTR từng Line',
  'c-donut':   'Tỷ lệ mức độ sự cố tháng này',
  'hm-wrap':   'Heatmap sự cố theo giờ trong ngày',
  'pareto-list':'Pareto loại lỗi (80/20)',
  'cb':        'Sự cố hôm nay theo Line',
  'cl':        'MTTR 7 ngày gần nhất',
  'incidentChart': 'Thống kê loại cảnh báo trong ngày (Live Data)'
};
const ZSvg = `<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`;
window._charts = {};

function mkZoomBtn(targetId, title) {
  const b = document.createElement('button');
  b.className = 'zoom-btn';
  b.title = 'Phóng to';
  b.innerHTML = ZSvg;
  b.setAttribute('data-zbtn', '1');
  b.onclick = () => openZoom(targetId, title || ZOOM_TITLES[targetId] || '');
  return b;
}

function injectZoom() {
  // Thêm zoom vào Dashboard panel headers
  [
    { hdrId: 'lc-hdr',  zoomId: 'lc' },
    { hdrId: 'sc-hdr',  zoomId: 'sc' },
  ].forEach(({ hdrId, zoomId }) => {
    const hdr = document.getElementById(hdrId);
    if (!hdr || hdr.querySelector('[data-zbtn]')) return;
    hdr.appendChild(mkZoomBtn(zoomId));
  });

  // Thêm zoom vào AI panel
  const aiHdr = document.querySelector('.ai-header');
  if (aiHdr && !aiHdr.querySelector('[data-zbtn]')) {
    aiHdr.appendChild(mkZoomBtn('ai-panel', 'AI Insights'));
  }

  // Thêm zoom vào các box có class .cbox
  document.querySelectorAll('.cbox').forEach(box => {
    if (box.querySelector('[data-zbtn]')) return;
    const canvas = box.querySelector('canvas');
    const inner  = box.querySelector('[id]');
    const tid    = canvas ? canvas.id : (inner ? inner.id : null);
    if (!tid) return;
    const lbl   = box.querySelector('.cbox-label');
    const title = lbl ? lbl.textContent.trim() : (ZOOM_TITLES[tid] || '');
    const hdr   = document.createElement('div');
    hdr.className = 'panel-hdr';
    const sp = document.createElement('span');
    sp.className = 'panel-hdr-title';
    sp.textContent = title;
    hdr.appendChild(sp);
    hdr.appendChild(mkZoomBtn(tid, title));
    if (lbl) lbl.replaceWith(hdr); else box.prepend(hdr);
  });
}

function openZoom(id, title) {
  const src = document.getElementById(id);
  if (!src) return;
  document.getElementById('mTitle').textContent = title || '';
  const mc = document.getElementById('mContent');
  mc.innerHTML = '';

  const canvas = src.tagName === 'CANVAS' ? src : src.querySelector('canvas');
  if (canvas && window._charts[canvas.id]) {
    const orig = window._charts[canvas.id];
    const w = document.createElement('div');
    w.style.cssText = 'position:relative;width:100%;height:500px';
    const nc = document.createElement('canvas');
    nc.id = canvas.id + '_z';
    w.appendChild(nc); mc.appendChild(w);
    try {
      new Chart(nc, {
        type: orig.config.type,
        data: JSON.parse(JSON.stringify(orig.config.data)),
        options: { ...JSON.parse(JSON.stringify(orig.config.options || {})), responsive: true, maintainAspectRatio: false }
      });
    } catch(e) {
      mc.innerHTML = '<p style="padding:20px;color:var(--text-secondary)">Không thể clone biểu đồ.</p>';
    }
  } else {
    // Clone thẻ DOM
    const cl = src.cloneNode(true);
    cl.removeAttribute('id');
    cl.querySelectorAll('[data-zbtn],[id^="ti-"]').forEach(e => e.remove());
    cl.querySelectorAll('[id]').forEach(e => e.removeAttribute('id'));
    cl.style.fontSize = '14px';
    mc.appendChild(cl);
  }

  const ov = document.getElementById('mOv');
  ov.style.display = 'flex';
  requestAnimationFrame(() => ov.style.opacity = '1');
  document.addEventListener('keydown', escCl);
}

function closeZoom() {
  const ov = document.getElementById('mOv');
  ov.style.opacity = '0';
  setTimeout(() => ov.style.display = 'none', 200);
  document.querySelectorAll('[id$="_z"]').forEach(c => { const ch = Chart.getChart(c); if (ch) ch.destroy(); });
  document.removeEventListener('keydown', escCl);
}
function escCl(e) { if (e.key === 'Escape') closeZoom(); }

// Patch Chart
const _OC = Chart;
window.Chart = function(el, cfg) {
  const inst = new _OC(el, cfg);
  if (el && el.id) window._charts[el.id] = inst;
  return inst;
};
Object.setPrototypeOf(window.Chart, _OC);
Object.assign(window.Chart, _OC);
window.Chart.prototype = _OC.prototype;

