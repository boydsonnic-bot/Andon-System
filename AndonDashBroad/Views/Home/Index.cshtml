function renderHist(data) {
  const sc={Red:'#dc2626',Yellow:'#d97706'};
  document.getElementById('hb').innerHTML=data.map(r=>`<tr>
    <td>${r.dt} ${r.tm}</td><td>${r.line}</td>
    <td style="max-width:110px;overflow:hidden;text-overflow:ellipsis">${r.stn}</td>
    <td style="max-width:120px;overflow:hidden;text-overflow:ellipsis">${r.al}</td>
    <td><span class="badge" style="background:${sc[r.sev]||'#888'}18;color:${sc[r.sev]||'#888'};border:0.5px solid ${sc[r.sev]||'#888'}50">${r.sev}</span></td>
    <td>${r.dur}m</td><td>${r.op}</td><td>${r.tech}</td><td>${r.lead}</td>
    <td style="font-family:monospace">${r.wo}</td>
  </tr>`).join('');
  document.getElementById('hist-count').textContent=data.length+' bản ghi';
}
function doFilter() {
  const fl=document.getElementById('f-line').value,fs=document.getElementById('f-stn').value,fw=document.getElementById('f-wo').value.toLowerCase();
  renderHist(allH.filter(r=>{
    if(fl&&r.line!==LS.find(l=>l.id===fl)?.nm)return false;
    if(fs&&r.stn!==fs)return false;
    if(fw&&!r.wo.toLowerCase().includes(fw))return false;
    return true;
  }));
}
function resetFilter() {
  ['f-line','f-stn','f-shift','f-wo'].forEach(id=>document.getElementById(id).value='');
  renderHist(allH);
}

