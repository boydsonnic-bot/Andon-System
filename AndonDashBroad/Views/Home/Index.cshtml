  'cb':'Sự cố hôm nay theo Line','cl':'MTTR 7 ngày gần nhất',
};
const ZSvg = `<svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/><line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/></svg>`;
window._charts = {};

function mkZoomBtn(tid, title) {
  const b = document.createElement('button');
  b.className = 'zoom-btn'; b.title = 'Phóng to'; b.innerHTML = ZSvg;
  b.setAttribute('data-zbtn','1');
  b.onclick = () => openZoom(tid, title || ZOOM_TITLES[tid] || '');
  return b;
}
function injectZoom() {
  [{hdrId:'lc-hdr',zoomId:'lc'},{hdrId:'sc-hdr',zoomId:'sc'}].forEach(({hdrId,zoomId})=>{
    const hdr=document.getElementById(hdrId);
    if(!hdr||hdr.querySelector('[data-zbtn]'))return;
    hdr.appendChild(mkZoomBtn(zoomId));
  });
  const aiHdr=document.querySelector('.ai-header');
  if(aiHdr&&!aiHdr.querySelector('[data-zbtn]')) aiHdr.appendChild(mkZoomBtn('ai-panel','AI Insights'));
  document.querySelectorAll('.cbox').forEach(box=>{
    if(box.querySelector('[data-zbtn]'))return;
    const canvas=box.querySelector('canvas'),inner=box.querySelector('[id]');
    const tid=canvas?canvas.id:(inner?inner.id:null);if(!tid)return;
    const lbl=box.querySelector('.cbox-label'),title=lbl?lbl.textContent.trim():(ZOOM_TITLES[tid]||'');
    const hdr=document.createElement('div');hdr.className='panel-hdr';
    const sp=document.createElement('span');sp.className='panel-hdr-title';sp.textContent=title;
    hdr.appendChild(sp);hdr.appendChild(mkZoomBtn(tid,title));
    if(lbl)lbl.replaceWith(hdr);else box.prepend(hdr);
  });
}
function openZoom(id,title){
  const src=document.getElementById(id);if(!src)return;
  document.getElementById('mTitle').textContent=title||'';
  const mc=document.getElementById('mContent');mc.innerHTML='';
  const canvas=src.tagName==='CANVAS'?src:src.querySelector('canvas');
  if(canvas&&window._charts[canvas.id]){
    const orig=window._charts[canvas.id],w=document.createElement('div');
    w.style.cssText='position:relative;width:100%;height:500px';
    const nc=document.createElement('canvas');nc.id=canvas.id+'_z';
    w.appendChild(nc);mc.appendChild(w);
    try{new Chart(nc,{type:orig.config.type,data:JSON.parse(JSON.stringify(orig.config.data)),
      options:{...JSON.parse(JSON.stringify(orig.config.options||{})),responsive:true,maintainAspectRatio:false}});}
    catch(e){mc.innerHTML='<p style="padding:20px;color:var(--text-secondary)">Không thể clone biểu đồ.</p>';}
  } else {
    const cl=src.cloneNode(true);cl.removeAttribute('id');
    cl.querySelectorAll('[data-zbtn],[id^="ti-"]').forEach(e=>e.remove());
    cl.querySelectorAll('[id]').forEach(e=>e.removeAttribute('id'));
    cl.style.fontSize='14px';mc.appendChild(cl);
  }
  const ov=document.getElementById('mOv');
  ov.style.display='flex';requestAnimationFrame(()=>ov.style.opacity='1');
  document.addEventListener('keydown',escCl);
}
function closeZoom(){
  const ov=document.getElementById('mOv');ov.style.opacity='0';
  setTimeout(()=>ov.style.display='none',200);
  document.querySelectorAll('[id$="_z"]').forEach(c=>{const ch=Chart.getChart(c);if(ch)ch.destroy();});
  document.removeEventListener('keydown',escCl);
}
function escCl(e){if(e.key==='Escape')closeZoom();}

// Patch Chart để lưu instances cho zoom
const _OC=Chart;
window.Chart=function(el,cfg){const inst=new _OC(el,cfg);if(el&&el.id)window._charts[el.id]=inst;return inst;};
Object.setPrototypeOf(window.Chart,_OC);Object.assign(window.Chart,_OC);window.Chart.prototype=_OC.prototype;

setTimeout(injectZoom,350);
</script>

<!-- MODAL ZOOM -->
<div id="mOv" onclick="if(event.target===this)closeZoom()"
  style="display:none;opacity:0;position:fixed;inset:0;background:rgba(0,0,0,.48);z-index:9999;
         align-items:center;justify-content:center;padding:20px;transition:opacity .2s">
  <div style="background:var(--bg-primary);border-radius:12px;border:0.5px solid var(--border);
       width:100%;max-width:1060px;max-height:92vh;overflow:auto;padding:16px 18px 20px;position:relative">
    <button onclick="closeZoom()"
      style="position:absolute;top:10px;right:10px;width:28px;height:28px;border:0.5px solid var(--border);
             border-radius:6px;background:none;cursor:pointer;color:var(--text-secondary);
             display:flex;align-items:center;justify-content:center;font-size:15px;font-family:inherit">✕</button>
    <div id="mTitle" style="font-size:13px;font-weight:500;margin-bottom:14px;padding-right:36px;color:var(--text-primary)"></div>
    <div id="mContent"></div>
  </div>
</div>
</body>
</html>
