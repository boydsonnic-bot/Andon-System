function initInsights() {
  if (window._insInit) return; window._insInit = true;

  const avgAv   = (LS.reduce((a,l)=>a+l.av,0)/(LS.length||1)).toFixed(1);
  const avgMttr = Math.round(LS.filter(l=>l.mttr>0).reduce((a,l)=>a+l.mttr,0)/(LS.filter(l=>l.mttr>0).length||1));
  const avgMtbf = Math.round(LS.filter(l=>l.mtbf>0).reduce((a,l)=>a+l.mtbf,0)/(LS.filter(l=>l.mtbf>0).length||1));
  const totInc  = LS.reduce((a,l)=>a+l.inc,0);
  const active  = LS.filter(l=>l.s!=='green').length;

  document.getElementById('kpi-ribbon').innerHTML = [
    {cls:'kpi-g', l:'Availability TB',  v:avgAv+'%',   d:'Mục tiêu ≥ 95%'},
    {cls:'kpi-b', l:'MTTR TB',          v:avgMttr+'m', d:'Mean Time To Repair'},
    {cls:'kpi-t', l:'MTBF TB',          v:avgMtbf+'m', d:'Mean Time Between Failures'},
    {cls:'kpi-r', l:'Line đang lỗi',    v:active,      d:'Trong tổng '+LS.length+' Line'},
    {cls:'kpi-y', l:'Sự cố hôm nay',    v:totInc,      d:'Tất cả loại'},
    {cls:'kpi-p', l:'Response rate',    v:'87%',        d:'KTV phản hồi trong 5p'},
  ].map(k=>`<div class="kpi ${k.cls}"><div class="kpi-l">${k.l}</div><div class="kpi-v">${k.v}</div><div class="kpi-d" style="color:var(--text-tertiary)">${k.d}</div></div>`).join('');

