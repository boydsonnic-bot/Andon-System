async function genHints() {
  const hints = [];
  const active = LS.filter(l => l.s !== 'green');
  
  active.filter(l => l.s === 'red').forEach(l => {
    const mins = Math.floor((Date.now()-l.ts)/60000);
    hints.push({type:'critical', title:`${l.nm} dừng đã ${mins}m`, sub:`${l.stn} · ${l.al}${l.tech?'':' · Chưa có KTV'}`, tag:'Khẩn cấp'});
  });

  for (let line of LS) {
      if (line.inc > 0) {
          try {
              let res = await fetch(`/api/analytics/zscore?line=${line.nm}&threshold=2.0`);
              let data = await res.json();
              if (data && data.outliers && data.outliers.length > 0) {
                  hints.push({type:'critical', title:`Bất thường tại ${line.nm}`, sub:`Có ${data.outliers.length} sự cố sửa quá lâu so với TB (${data.mean}m)`, tag:'Z-Score'});
              }
          } catch (e) { }
      }
  }

  const tramDangLoi = active.map(l => l.stn);
  for (let stn of tramDangLoi) {
      try {
          let res = await fetch(`/api/analytics/pattern?station=${stn}&n=2`);
          let data = await res.json();
          if (data && data.patterns && data.patterns.length > 0) {
              let topPattern = data.patterns[0];
              hints.push({type:'info', title:`💡 Dự đoán lỗi tại ${stn}`, sub:`Quy luật: Lỗi '${topPattern.pattern}' lặp lại ${topPattern.frequency} lần.`, tag:'AI Pattern'});
          }
      } catch (e) { }
  }

  if (hints.length === 0) hints.push({type:'good', title:'Chỉ số trong ngưỡng an toàn', sub:'Chưa phát hiện rủi ro', tag:'Bình thường'});

  const ico = {
    critical:`<svg viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z"/></svg>`,
    warn:    `<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm-1 5h2v6h-2V7zm0 8h2v2h-2v-2z"/></svg>`,
    good:    `<svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>`,
    info:    `<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm-1 5h2v6h-2V7zm0 4h2v6h-2v-6z"/></svg>`,
  };

  document.getElementById('hint-list').innerHTML = hints.slice(0,7).map(h => `<div class="hint hint-${h.type}"><div class="hint-ico">${ico[h.type]}</div><div class="hint-body"><div class="hint-title">${h.title}</div><div class="hint-sub">${h.sub}</div><span class="hint-tag">${h.tag}</span></div></div>`).join('');
}

