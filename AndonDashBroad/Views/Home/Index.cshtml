// ============================================================
// AI HINTS ENGINE
// ============================================================
function genHints() {
  const hints   = [];
  const active  = LS.filter(l => l.s !== 'green');
  const avgMttr = LS.filter(l=>l.mttr>0).reduce((a,l)=>a+l.mttr,0) / (LS.filter(l=>l.mttr>0).length||1);

  active.filter(l => l.s === 'red').forEach(l => {
    const mins = Math.floor((Date.now()-l.ts)/60000);
    hints.push({type:'critical', title:`${l.nm} dừng đã ${mins}m`, sub:`${l.stn} · ${l.al}${l.tech?'':' · Chưa có KTV nhận'}`, tag:'Khẩn cấp'});
  });
  active.filter(l => l.s === 'yellow' && !l.tech).forEach(l => {
    const mins = Math.floor((Date.now()-l.ts)/60000);
    if (mins > 5) hints.push({type:'warn', title:`${l.nm} chờ KTV ${mins}m`, sub:`${l.al} · Cần phân công KTV ngay`, tag:'Chờ xử lý'});
  });
  LS.filter(l => l.mttr > avgMttr*1.4 && l.mttr > 0).forEach(l => {
    hints.push({type:'warn', title:`MTTR ${l.nm} cao bất thường`, sub:`${l.mttr}p · TB ${Math.round(avgMttr)}p · Gấp ${(l.mttr/avgMttr).toFixed(1)}x`, tag:'Hiệu suất'});
  });
  LS.filter(l => l.av < 90 && l.av > 0).forEach(l => {
    hints.push({type:'warn', title:`Availability ${l.nm} dưới ngưỡng`, sub:`${l.av}% · Mục tiêu ≥ 90% · ${l.inc} sự cố hôm nay`, tag:'OEE'});
  });
  active.filter(l => l.s === 'orange' && l.ts).forEach(l => {
    const mins = Math.floor((Date.now()-l.ts)/60000);
    if (mins > l.mttr*1.5 && l.mttr > 0)
      hints.push({type:'info', title:`${l.nm} vượt MTTR dự kiến`, sub:`Đang sửa ${mins}m · MTTR TB ${l.mttr}m · ${l.tech?l.tech.nm:'KTV'}`, tag:'Theo dõi'});
  });
  const good = LS.filter(l => l.s === 'green' && l.av >= 95);
  if (good.length > 0)
    hints.push({type:'good', title:`${good.length} Line hoạt động tốt`, sub:good.map(l=>l.nm).join(', ')+' · Availability ≥ 95%', tag:'Ổn định'});
  const h = new Date().getHours();
  if (h >= 9 && h <= 11)
    hints.push({type:'info', title:'Đang trong khung giờ cao điểm', sub:'9-11h thường có sự cố nhiều nhất theo lịch sử', tag:'Lịch sử'});
  if (hints.length === 0)
    hints.push({type:'good', title:'Tất cả chỉ số trong ngưỡng an toàn', sub:'Không phát hiện bất thường trong ca hiện tại', tag:'Bình thường'});

  const ico = {
    critical:`<svg viewBox="0 0 24 24"><path d="M12 2L1 21h22L12 2zm0 3.5L20.5 19h-17L12 5.5zM11 10v4h2v-4h-2zm0 6v2h2v-2h-2z"/></svg>`,
    warn:    `<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm-1 5h2v6h-2V7zm0 8h2v2h-2v-2z"/></svg>`,
    good:    `<svg viewBox="0 0 24 24"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>`,
    info:    `<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 100 20A10 10 0 0012 2zm-1 5h2v2h-2V7zm0 4h2v6h-2v-6z"/></svg>`,
  };
  document.getElementById('hint-list').innerHTML = hints.slice(0,7).map(h => `
    <div class="hint hint-${h.type}">
      <div class="hint-ico">${ico[h.type]}</div>
      <div class="hint-body">
        <div class="hint-title">${h.title}</div>
        <div class="hint-sub">${h.sub}</div>
        <span class="hint-tag">${h.tag}</span>
      </div>
    </div>`).join('');
}

